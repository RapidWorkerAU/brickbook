<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_9483a51b-3e90-4dc8-bca3-31c14ae34724" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>F6D6</sptc><title id="_9f672c42-18ec-4745-b5fc-bf34f46efd7c">Ventilation</title><archive-num>2019: F4.5</archive-num><clause-variation href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4293_2.7.0.xml" variation="NSW" variation-type="REPLACE">NSW REPLACE Clause</clause-variation><subclause id="_21749348-a242-4ba9-8706-635c0c740dda" outputclass="subclause"><title id="_57964099-79b6-4a74-b61d-c7811ce72f5e">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1326_0.4.0.xml#_b8eec66f-9c05-425d-8474-e6a2dfc2c0f4" id="_75a8f3bf-61d9-4ea0-a192-fab082af2c70" scope="local" type="abcb-glossentry">habitable room</xref>, office, shop, factory, workroom, <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1445_0.13.0.xml#_b30a308f-eb9f-4549-a6c1-19d5f32a5272" id="_b967d740-3702-4c91-b262-2ab2ad89278d" scope="local" type="abcb-glossentry">sanitary compartment</xref>, bathroom, shower room, laundry and any other room or space occupied by a person for any purpose must have—</p><ol outputclass="alpha"><li id="_53412115-5cbc-4b60-aecd-0a2ad1e5d489">natural ventilation complying with—<ol><li><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/2825_2.3.0.xml#_6a128f81-6a20-4609-bb23-572c9fbbb182" id="_6c7f7402-52c3-4fc4-ba4b-a02ed9f1b7da" scope="local" type="clause">F6D7</xref>; or</li><li>AS 1668.4; or</li></ol></li><li id="_89038cee-ac42-4210-a59d-4ba98f9fba70">a mechanical ventilation or air-conditioning system complying with AS 1668.2 and AS/NZS 3666.1.</li></ol></subclause></clause>