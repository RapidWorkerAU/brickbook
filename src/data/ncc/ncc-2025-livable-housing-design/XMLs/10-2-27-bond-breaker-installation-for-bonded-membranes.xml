<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_536800ea-b909-43e5-9d39-2807a37341f3" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10b"/></meta><sptc>10.2.27</sptc><title id="_7bb55b78-4768-4c79-9356-c0a20299e1f4">Bond breaker installation for bonded membranes</title><archive-num>New for 2022</archive-num><subclause id="_14c4ca94-2d27-4e88-a50d-5e15781a2a9c" outputclass="subclause"><title id="_6086e433-75cc-4449-904d-d5f0ebbbde07">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_74658b09-3e84-459d-b7fe-28e844a07ed8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Bond breakers</xref> must be installed at all wall/wall, wall/floor, <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4660_0.4.0.xml#_6daa7d7f-9147-4c10-98bc-c3cee9774bdb" id="_744e6126-3769-4e9f-91d4-ba5dfb2a86d4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">hob</xref>/wall junctions and at movement joints where the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_128eb3c2-8215-475b-adeb-a4429f2452be" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> is bonded to the substrate.</p></subclause><subclause id="_1e5ab077-e9be-400f-9982-04f2eb28edb1" outputclass="subclause"><title id="_6100b27d-9a27-4fec-95d6-3809f1160c57">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_1a53b2a5-0fc1-4504-8f35-35a217f63f87" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Bond breakers</xref> must be of the type compatible with the flexibility class of the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_c291cead-8fc4-4eaf-8b0f-7a433e4cf165" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> to be used.</p></subclause><callout id="_43d6068d-2d00-49b2-b00b-839c55283276"><callout-type ncc-info-type="info"/><p>Typical details for <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_60c733c6-1980-43cb-9945-77b8a175aaa3" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">bond breaker</xref> types are given in <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4761_0.16.0.xml#_291d6f2c-50d3-4546-8e8e-d1cbafdee61f" id="_422b0ba3-6656-41ae-b06b-87e81c4f7fad" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Explanatory Figure 10.2.27</xref>.</p><image-reference author="Brandon Kiem" conref="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4761_0.16.0.xml" dateTime="2021-03-01T10:51:00" id="_291d6f2c-50d3-4546-8e8e-d1cbafdee61f" type="insert"><num/><title id="_a758530c-2df7-45f5-8245-346c0c85a527"/></image-reference></callout></clause>