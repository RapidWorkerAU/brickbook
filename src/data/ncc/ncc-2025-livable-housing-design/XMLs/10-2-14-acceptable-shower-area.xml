<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_f01f1a8e-5c5d-444a-8f8f-9611cad9709a" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10b"/></meta><sptc>10.2.14</sptc><title id="_ef032d12-eaf7-433a-9397-0d14d4b2c141">Shower area requirements</title><archive-num>New for 2022</archive-num><subclause id="_373540de-75c6-4325-89bd-a18a29162d81" outputclass="subclause"><title id="_463026af-dccf-4acc-8649-1564604ef04b">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1460_0.12.0.xml#_6aa99639-a955-4628-bc59-dabb3bfc8118" id="_3db65c02-ebae-4ee2-9670-3afa9e2bc03b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Shower areas</xref> must be designed as either <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1460_0.12.0.xml#_d537d27e-a0b2-4b16-951c-fda3295e3ac7" id="_c09da462-5db6-4765-9870-87678695ac36" referencetype="Text" scope="local" synctargettext="false" type="glossterm">enclosed</xref> or <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1460_0.12.0.xml#_d537d27e-a0b2-4b16-951c-fda3295e3ac7" id="_4ae3e332-851b-4af4-8249-e86e9536f80e" referencetype="Text" scope="local" synctargettext="false" type="glossterm">unenclosed</xref>.</p></subclause><subclause id="_607596c5-f8af-467f-9a42-f342e5da368a" outputclass="subclause"><title id="_8dc9db9c-72be-48fe-8aaa-43515e5fa783">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1460_0.12.0.xml#_6aa99639-a955-4628-bc59-dabb3bfc8118" id="_0d1a296c-fa0f-4d07-a7eb-903744de1ff5" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Shower areas</xref> must incorporate a <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4659_0.3.0.xml#_3aa47b15-8473-4ba3-ae33-cf9b2d99ad0b" id="_5a1e2841-7bc8-46f7-8210-b62716f8986c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">floor waste</xref> with falls complying with <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4716_0.13.0.xml#_6948d9ae-f62a-45d9-9f0d-be0dd68b6ac6" id="_35752c7f-2579-408b-a22a-900232eb322f" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">10.2.12</xref>.</p></subclause><subclause id="_ce18a1c1-e5f1-4a8d-ae1c-57e797e0ceb7" outputclass="subclause"><title id="_3e10c7c6-3100-4252-a43b-eb5bd1920871">SubClause</title><num>3</num><p><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/1460_0.12.0.xml#_6aa99639-a955-4628-bc59-dabb3bfc8118" id="_00d4e6b4-83ac-4732-a03d-7300109add30" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Enclosed shower areas</xref> must incorporate—</p><ol outputclass="alpha"><li id="_5de6a5b3-6251-48b8-a736-70ec5ceaf849">stepdown complying with <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4730_0.14.0.xml#_531488bd-5761-494a-935a-7b83a0bf213b" id="_1b080275-e5b8-412a-b2c3-f21fa134d805" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">10.2.15</xref>; or</li><li id="_672cafc8-f6d3-4398-a613-1c5a7904e154"><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4660_0.4.0.xml#_6daa7d7f-9147-4c10-98bc-c3cee9774bdb" id="_1d7b43f8-2638-4add-94c6-54ce7a5bb8c0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">hob</xref>