<?xml version="1.0" encoding="UTF-8" standalone="no"?><image-reference xmlns:xt="urn:xpressauthor:trackchanges" id="_291d6f2c-50d3-4546-8e8e-d1cbafdee61f"><num>10.2.27 (explanatory)</num><title id="_a758530c-2df7-45f5-8245-346c0c85a527">Typical bond breaker details</title><image alt="Typical bond breaker details" height="1800" heightdpi="200" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/10-2-27-explanatory-typical-bond-breaker-details.svg" width="1188" widthdpi="200"/><desc-note id="_63a997a3-099a-4925-8a33-20331295d4ac"><ol outputclass="numbered"><li id="_aebd4bd8-aa26-47da-b4bc-df5995dae758"><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_e9e6f83e-3abc-41f7-91f7-8212d1247d63" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Bond breakers</xref> for Class I <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_5b35f462-3a1a-433c-95c1-3cf779dccc1a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membranes</xref> (low extensibility) allow the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_469cfeb8-4987-4259-9828-9820f2a622f4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> to flex rather than stretch.</li><li id="_7f45f565-37d1-4acf-8a78-d566601c882b"><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_2145fd45-18ca-48ec-a629-0fb4e467d216" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Bond breakers</xref> for Class II <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_482fd307-1d96-43de-b9dc-e48824fc7c7d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membranes</xref> (medium extensibility) allow the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_935ee85a-aefe-4b00-810b-656cf5526d9a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> to stretch. If a tape is used as a <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_871aa9ce-95a2-44fc-8281-e1da7e19b407" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">bond breaker</xref>, either the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_bfcb6600-fb72-4d4b-b92e-d2206870feb1" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> must not bond to the tape or the tape must have elastic properties similar to the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_4a47cf0e-32c5-4e16-aeae-f1dd77994fc2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref>.</li><li id="_c21b797e-7521-43cf-9844-fd8b7bd060f5"><xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4653_0.4.0.xml#_ca63ce08-6baa-457f-89f2-baac687e148e" id="_8c8ed474-87dd-4dd7-8b67-0fec3c6397a8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Bond breakers</xref> for Class III <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_59286185-8701-4195-9a54-94ab4ee0ff18" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membranes</xref> (high extensibility) allow the <xref format="dita" href="/tmp/QppServer/Publishing/2abe2d62-a871-4509-969b-2425466626a4/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_a934a415-46ac-47d6-b950-3c4066dca53f" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> to have an even thickness.</li></ol></desc-note></image-reference>