<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_90d7a57f-8530-499c-ba8e-7a803b15a6be" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>S40C2</sptc><title id="_58f55401-81a6-46c7-b882-e8225c1b863b">Manual switch</title><archive-num>2019: Spec J6: 2</archive-num><subclause id="_32feed83-4a2e-406c-91cd-18cb8f9a3e8b" outputclass="subclause"><title id="_8229259e-daa6-44e3-8ee3-63ef229577f9">SubClause</title><num>1</num><p>An artificial lighting manual switch must be located in a visible and easily accessed position—</p><ol outputclass="alpha"><li id="_ff70409e-231d-4108-b628-6cda4166dbb8">in the room or space being switched; or</li><li id="_c5a6c0fe-2f7d-4be9-bcb6-28fb64ce97a0">in an adjacent room or space from where at least 90% of the lighting being controlled is visible.</li></ol><p/></subclause></clause>