<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_d0b6cb8e-1dac-43e3-9cac-9a6bac0c65a4" outputclass="ncc-clause" variation="SA"><sptc>I4D2</sptc><title id="_bfc3feec-ecd7-4660-ac12-826a1b6ca35e">Type of construction required</title><subclause id="_4f50d753-c7f1-44b4-b65c-736a4e483e41" outputclass="subclause"><title id="_7d1c38d4-0f2d-450c-a353-bc37c302d3e1">SubClause</title><num>1</num><p>The external walls of a <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/2466_1.0.0.xml#_0ea6e30e-b7ce-4b3d-ab37-7888621a4eac" id="_d37e5c71-c7c9-4083-bdc5-9fa50d982e39" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">bulk grain storage facility</xref> need not be of fire-resisting construction in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/13_0.5.0.xml#_277b7bae-fe26-4d08-893c-0d9d7bde479d" id="_411759d1-2b10-4d7c-9e51-1b3337b59330" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table C2D2</xref> if—</p><ol outputclass="alpha"><li id="_94b1e57c-fb7f-439a-aab3-6f5b6738a8b2">the external walls are 3 m or more from an allotment boundary and more than 6 m from any other building on the same allotment, other than a Class 10 building; and</li><li id="_db285cfd-aae1-45f6-8dc9-56e67385fe6c">a fire separation space of not less than 2 m is provided between <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/2468_0.7.0.xml#_77fc5383-ae28-4bfd-ad12-0d5735cf1366" id="_57b4caa5-5dbb-4ed9-bf6e-940555914481" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cell type silos</xref>; and</li><li id="_d4628c2e-f5f6-41ab-a61c-0c1a590396bf">the external walls are of—<ol><li>non-combustible construction; or</li><li>Type C construction.</li></ol></li></ol></subclause></clause>