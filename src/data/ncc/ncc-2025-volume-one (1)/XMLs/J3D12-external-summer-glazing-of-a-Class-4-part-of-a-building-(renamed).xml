4154-8539-afc815034863/1373_0.7.0.xml#_f68246d9-7a77-41fc-8050-516881323e47" id="_211b2327-f669-4132-b79b-9ffe1b67ec1a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">mezzanine</xref>, of a Class 4 part of a building must—</p><ol outputclass="alpha"><li id="_e05b5ac9-66dd-40fb-b182-427cb1aa9417">not exceed the allowance resulting from multiplying the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1314_2.10.0.xml#_7da927fe-453e-424f-b6ec-280f4e464397" id="_9e27e07b-e178-4ef3-83a6-cfdd36b52f8d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">floor area</xref> of the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1483_25.0.0.xml#_53ff3ea1-55e7-4f2a-b2b3-ca445ff64c15" id="_5e9b4617-653c-4f45-87d1-d81f5f0d4e00" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">storey</xref>, including any <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1373_0.7.0.xml#_f68246d9-7a77-41fc-8050-516881323e47" id="_9d78bcd4-6f7f-41ab-8f85-2071bab96d3a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">mezzanine</xref>, measured within the enclosing walls, by the constant C<sub id="_86c99a34-440a-4708-8f23-dd346ae51d61">SHGC</sub> obtained from <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6358_0.11.0.xml#_be0ae543-86f7-44d9-b94c-650c8bd9638d" id="_72a0d914-9ea9-4a66-b287-3893971c29d8" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D12a</xref>; and</li><li id="_8ec6c760-b1f1-41d5-94ef-f9538ae61b15">be calculated in accordance with the following formula: </li></ol><p><equation-inline alignEquation="center" height="24" heightdpi="96" id="_25c7d86a-1a60-40ad-9ecd-5b444540997f" width="491" widthdpi="96"><mathML><math><semantics><mrow><mo stretchy="false">(</mo><msu