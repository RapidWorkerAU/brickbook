<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_038b4f49-ad8e-4f10-8dc3-19619a85fb0d" outputclass="ncc-clause" variation="NSW"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>H7D4</sptc><title id="_2147f6db-5109-4373-acf1-4bfaa9968943">Construction in bushfire prone areas</title><archive-num>2019: NSW 3.10.5.0</archive-num><subclause id="_0e6bb536-208e-44d6-9a7f-e55b321083f5" outputclass="subclause"><title id="_05443e54-6bde-4c26-8f20-f95bfc9d6b21">SubClause</title><num>1</num><p>The requirements of (2) only apply in a <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1243_0.7.0.xml#_2c223137-7ce5-4993-bd69-503e243c9453" id="_fb01daa0-1602-4ef1-a860-9a1566e76346" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">designated bushfire prone area</xref>.</p></subclause><subclause id="_86533eb7-1299-42b6-ab3e-f41233296b48" outputclass="subclause"><title id="_6bc01278-9ac6-4350-a40b-760b492e5e28">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_3b678fa3-b0c6-4cd6-beb1-1b923bdb3177" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Performance Requirement</xref> <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10646_0.3.0.xml#_2d01ea8d-3321-465c-ba02-4ead1486fc8f" id="_0e23eea9-4494-4aba-a223-4f77306160c1" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW H7P5</xref> is satisfied for a Class 1 buil