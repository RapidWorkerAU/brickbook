<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_b3afb320-4c7c-424d-b261-c208cb8eccc8" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>J5D4</sptc><title id="_5dac1d6d-d69f-4503-886e-0708477062d9">Roof lights</title><archive-num/><subclause id="_1e2c19bd-61c2-4086-a5a0-959a5ccebbd3" outputclass="subclause"><title id="_80da96b8-dd11-4c8e-ab5a-d0add29592f8">SubClause</title><num/><p>A <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1441_5.5.0.xml#_12b88f11-1c3d-4d91-bc65-02588a4dc524" id="_1ee42823-4efc-4ee5-ba09-a9daecdc2939" scope="local" type="abcb-glossentry">roof light</xref> must be sealed, or capable of being sealed, with—</p><ol outputclass="alpha"><li id="_d5fab577-a706-4bca-9709-1a48e2572e3b">an imperforate ceiling diffuser or the like installed at the ceiling or internal lining level; or</li><li id="_1064b477-6336-4c37-b00b-e1f80f7ef98c">a weatherproof seal; or</li><li id="_77adc8f2-6900-432b-ad49-83c184f634ac">a shutter system readily operated either manually, mechanically or electronically by the occupant.</li></ol></subclause></clause>