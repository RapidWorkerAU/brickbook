<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_5b3a7bb4-be2c-487e-a3ca-0797277cce01" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>J5D6</sptc><title id="_d7afe896-8c3c-4d0a-aceb-cfb8c95be054">Exhaust fans</title><archive-num/><subclause id="_c1dd2f7f-22d0-4b16-9a43-7cf36bed1306" outputclass="subclause"><title id="_11734e33-95e9-42bc-8fd6-c7e44f51badc">SubClause</title><num>1</num><p>An exhaust fan must be fitted with a sealing device such as a self-closing damper or the like unless it is necessary for the fan to operate continuously.</p></subclause></clause>