<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_3ab8e0d4-b998-4cbc-86eb-f4a758332255" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>S37C7</sptc><title id="_77d2dacd-823d-48c7-8740-244c4b7ae45b">Shading</title><archive-num>2019: Spec J1.5a: 7</archive-num><subclause id="_26b73662-a21d-4615-9756-d7a077ad823d" outputclass="subclause"><title id="_b3ae25d5-dcc6-45fc-b5fa-ae094d58873d">SubClause</title><num>1</num><p>For the purpose of calculating <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1472_24.0.0.xml#_153f21fa-ec15-45c3-a716-b675e707f2e7" id="_fb769f99-3828-4d96-a27a-d033c5ebd197" scope="local" type="abcb-glossentry">solar admittance</xref>, the shading multiplier for each <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_49368b0b-1048-4ce7-b880-ef31bdc487d2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref> element is the lesser of—</p><ol outputclass="alpha"><li id="_a1e87576-110e-4354-9173-418da6a569e6">for shading provided by an external permanent projection that extends horizontally on both sides of the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_ddc036fe-4ebc-4945-a7ad-754303c847b4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref> for the same project distance P, as shown in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/530_0.12.0.xml#_4c5c6f74-f15b-42a4-a618-3a85ca80c889" id="_6c427da9-9aab-420f-bc52-b864698dfa3d" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Figure S37C7a</xref>—<ol><li>the value in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/326_0.8.0.xml#_d70d6719-2248-4c9e-95ce-f8c09d7734ac" id="_6e54dac1-16bb-47a8-b965-8018ccdc35d1" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table S37C7a</xref> for shading on the northern, eastern or western aspects; or</li><li>the value in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/327_0.7.0.xml#_a8660d13-6c90-46d8-9764-5bf15ac0b1c0" id="_1851b338-4031-457f-b13e-a4419e20e9ee" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table S37C7b</xref> for shading on the southern aspect; or</li></ol></li><li id="_38e409a8-9054-49b2-9035-d7e00ee9c524">for shading provided by an external permanent projection that extends vertically for the height of the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_e69aa74a-b290-4e59-b83d-4bdcb40b2aad" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref> for the same projection distance D, as shown in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9875_0.9.0.xml#_7456e73d-e18a-4c8c-9856-74e017be233c" id="_763f69e1-4afa-4832-93b2-6232103bd360" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Figure S37C7b</xref>—<ol><li>the value in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9869_0.7.0.xml#_35057608-b8a2-406a-a50a-034005c14a58" id="_3490263f-354f-4cac-b01a-5297de96e85c" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table S37C7c</xref> for shading on the northern aspect; or</li><li>the value in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9870_0.11.0.xml#_98a4b592-93e1-4300-9d3d-518686fbe92e" id="_3c90c63d-8406-4c84-abae-a0da8e17ebe3" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table S37C7d</xref> for shading on the western aspect; or</li><li>the value in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9871_0.8.0.xml#_70ef062c-9131-4472-929a-94dc78d5ce63" id="_4b324a72-9af7-4544-8e76-aeea1b5320f5" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table S37C7e</xref> for shading on the eastern aspect; or</li><li>1.0 for shading on the southern aspect; or</li></ol></li><li id="_e8615089-15bb-4c87-87c3-5a8d4ea90836">0.35 for shading that is provided by an external shading device such as a shutter, blind, vertical or horizontal building screen with blades, battens or slats, which—<ol><li>is capable of restricting at least 80% of summer solar radiation; and</li><li>if adjustable, will operate automatically in response to the level of solar radiation.</li></ol></li></ol></subclause><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/326_0.8.0.xml" graph="None" id="_d70d6719-2248-4c9e-95ce-f8c09d7734ac"><num/><title id="_706c4250-4304-47f1-8895-c08ded3968ed"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/327_0.7.0.xml" graph="None" id="_a8660d13-6c90-46d8-9764-5bf15ac0b1c0"><num/><title id="_6a42bf3d-b40e-4f7a-b1a0-a886b249f8d4"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9869_0.7.0.xml" graph="None" id="_35057608-b8a2-406a-a50a-034005c14a58"><num/><title id="_495f063f-096c-4331-a75e-13cb8472cdc1"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9870_0.11.0.xml" graph="None" id="_98a4b592-93e1-4300-9d3d-518686fbe92e"><num/><title id="_c48f7f73-9d16-4ebc-8ca2-f4e807f7a574"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9871_0.8.0.xml" graph="None" id="_70ef062c-9131-4472-929a-94dc78d5ce63"><num/><title id="_2321b6ca-056b-40df-a0ba-fe01d0869aa7"/></table-reference><image-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/530_0.12.0.xml" id="_4c5c6f74-f15b-42a4-a618-3a85ca80c889"><num/><title id="_d15150e0-39bf-4501-9658-230e3e50af2f"/></image-reference><image-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/9875_0.9.0.xml" id="_7456e73d-e18a-4c8c-9856-74e017be233c"><num/><title id="_0876e7d3-f929-4b2b-b636-f8e8aad624e8"/></image-reference></clause>