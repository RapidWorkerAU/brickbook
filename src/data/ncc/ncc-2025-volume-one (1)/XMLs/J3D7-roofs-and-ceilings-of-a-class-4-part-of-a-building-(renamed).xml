<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:qxa="true" xmlns:xt="urn:xpressauthor:trackchanges" author="Brandon Kiem" dateTime="2021-06-21T15:57:07" id="_a6d16a7c-f9de-4374-801f-9fce33363e6f" outputclass="ncc-clause" type="insert"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 3"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>J3D7</sptc><title id="_d4ca891a-83d5-40ff-ba6f-aafb0c9347e4">Roofs and ceilings of a Class 4 part of a building</title><archive-num/><subclause id="_e3aca210-bee2-46a3-be8e-0ef7dd6463c0" outputclass="subclause"><title id="_71ce7e5d-e3f1-43a9-946a-b602cd5879ce">SubClause</title><num>1</num><p>Roof and ceiling insulation must achieve the minimum <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_297d8813-cbfa-441e-be8b-bf76f868a6f3" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">R-Value</xref>—</p><ol outputclass="alpha"><li id="_8333d4d4-afba-4d45-b14c-5e8ccb081115">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_bd2fa581-ce35-454c-b9d8-48884dcfdf51" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 1, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6259_0.15.0.xml#_193b9818-e743-40b1-b622-966347f0f340" id="_a150b841-ae2d-4aa5-96a7-f8b81d2f8d2d" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7a</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6260_0.33.0.xml#_5d63432b-6cdf-4052-bd1f-f685b168963f" id="_338dc077-3f67-4f34-aa45-4792490cf7cd" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7b</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6261_0.20.0.xml#_326aacb3-2d3b-494d-8600-8446040c8e5d" id="_afdcccf5-85ac-49b0-97e0-eb04a70232c3" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7c</xref> as applicable; and</li><li id="_64b6b08e-68ec-4cee-b5c5-df7d011d97d8">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_29ebb6eb-e60d-4b22-9527-62e21ed011c8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 2, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6262_0.12.0.xml#_a6a4c83b-0da0-49d6-8986-b682c3622cfd" id="_b52bacab-7b43-404d-8e30-9acd26bbe973" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7d</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6263_0.19.0.xml#_4ec953c1-5c59-4e53-ad25-7ac38467102b" id="_6c5ba5ab-e733-4b28-8116-744e5656a14f" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7e</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6264_0.19.0.xml#_64f563df-4e58-4419-9f2e-1db60bbc25fe" id="_8f9daa2a-05fd-49a9-b1bc-c31ca44b8e33" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7f</xref> as applicable; and</li><li id="_632d90ff-3366-45ff-acc3-c3ead9ddf88c">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_2b8993d9-be0a-4a76-93e8-e689aea8a92f" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 3, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6265_0.10.0.xml#_d190d215-91d8-44e5-8c4b-7ee0b1c913db" id="_9d546d6c-d85e-40af-af4f-5f7cc12b34f4" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7g</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6266_0.32.0.xml#_cca4dec5-da74-4276-af12-3d4ceb065e2d" id="_8324229d-ce95-4016-88d0-28b1a3ba5679" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7h</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6267_0.20.0.xml#_e929de14-cf70-4d3e-8e84-22379e0ae8f8" id="_813493ed-5e02-4d83-bb26-1b53d2d74555" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7i</xref> as applicable; and</li><li id="_101169de-0dbe-46d1-b489-d0f76b7c30cc">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_097852ab-4c9c-4a06-82cb-987c35d9c186" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 4, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6268_0.11.0.xml#_4a3b991b-7eaa-4307-87ff-dd24f194dd51" id="_1a1c5679-452a-4aa9-8671-d122d62159eb" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7j</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6270_0.17.0.xml#_c94c743d-6fb8-4a6e-b898-2da0baf3644d" id="_503596f2-fdc6-4c86-9aaa-0ff33fe62a61" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7k</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6271_0.12.0.xml#_5757b994-46a0-456c-85e6-bba1ebf8391e" id="_b7396da1-69b0-4a12-b339-17b7efa01a71" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7l</xref> as applicable; and</li><li id="_4733856b-8e42-4fe6-b14f-7c72ab266406">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_131c3801-8ca8-4b00-afde-52802b37cda8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 5, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6273_0.11.0.xml#_deada076-ebc0-4652-a29e-35cda3b46182" id="_d58fd95c-98df-43ef-96a4-3069e3d4f8d0" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7m</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6274_0.22.0.xml#_49c46bc9-88a8-4075-8c9b-7b4b985791d8" id="_2be7c2ce-3289-4960-8c43-f5c02636858f" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7n</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6275_0.11.0.xml#_bf266037-5a29-4c2d-9858-1403ac8df5c7" id="_736049ae-6666-4f8a-a7e0-600782c4c6be" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7o</xref> as applicable; and</li><li id="_107a56d9-8678-4036-8fbd-def805aba813">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_fed4178f-e15b-489b-b1cf-e879e1df09a0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 6—<ol outputclass="alpha"><li id="">R3.5; or</li><li>if the roof contains <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1427_4.6.0.xml#_710062da-7211-491f-ad4c-b3f12b9b96bb" id="_c0c7a0d6-0c29-4b45-997c-8b3fef4676b7" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reflective insulation</xref>, R3.0; and</li></ol></li><li id="_1cd96711-549b-442b-b83c-6b6383271184">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_037f0c40-385e-4e46-b545-01a5f0043e9d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 7 and 8, in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6276_0.14.0.xml#_4772e33e-f83d-4f00-a2ef-1f8a4bae48b7" id="_04bd6bb2-7026-4e1a-8ed6-9b42ab58cd74" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Tables J3D7p</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7405_0.5.0.xml#_8e636821-4d94-491f-8a30-7a82597c1e58" id="_0e7533d6-ce07-47ed-8362-5dd899e8fef4" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7q</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6278_0.14.0.xml#_9b28c94d-30f5-4bce-978b-6baf04f52036" id="_9944f598-c949-4a7d-b185-32b96f573a23" referencetype="Text" scope="local" synctargettext="false" type="table-reference">J3D7r</xref> as applicable.</li></ol></subclause><subclause id="_6dac5765-8050-4d77-8b45-3ca52eef0a94" outputclass="subclause"><title id="_045a0c21-8311-4474-8999-f3c0360e8117">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1427_4.6.0.xml#_710062da-7211-491f-ad4c-b3f12b9b96bb" id="_8d755f86-739c-4b06-9316-8fc3e6c6b01b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Reflective insulation</xref> installed to comply with (1) must—</p><ol outputclass="alpha"><li id="_2443dcd7-3995-4a62-8e6f-18f39a3ebc18">have a surface emittance of not more than 0.05; and</li><li id="_b81e8ea7-6e34-4f65-9610-5a6ab4ef68e4">be adjacent to a roof space of not less than 20 mm; and</li><li id="_afcc0f7a-b699-4e89-b164-d0c7ed379fe0">in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_58b93826-12bc-41ad-ab0d-bd103756bdca" id="_ff9eb9c7-2889-463a-9a6d-cb6ad3b80f4e" referencetype="Text" referredAs="_d4399006-6f94-491a-a37d-d60102afae17" scope="local" synctargettext="false" type="glossterm">climate zones</xref> 3 to 8, be downward facing.</li></ol></subclause><subclause id="_530f0cce-728a-4ae4-a866-e6b342a49b36" outputclass="subclause"><title id="_cc1e3bd5-aa23-41f8-a7a2-e29b499b5899">SubClause</title><num>3</num><p>The thermal bridging in a metal-framed roof must be addressed as follows—</p><ol outputclass="alpha"><li id="_c7e8fb0a-902a-4661-a905-da8c6ea5f5b6">for a pitched roof with a horizontal ceiling—<ol><li>achieving the <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1490_25.4.0.xml#_5a8cb42e-a549-40fa-a685-3422c624c5b7" id="_a068cce1-c2ea-42fe-b335-a491fb55ca97" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">Total R-Value</xref> in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6281_0.18.0.xml#_5bed239d-d208-4a8a-9aa6-7798c64c3eb4" id="_1d8a5b4c-fafb-4b73-b0fc-70167e402758" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D7s</xref>, calculated using a method that accounts for the effects of thermal bridging; or</li><li>increasing the <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_82f283d3-6855-404f-a07a-06e274f7af9f" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> of the insulation between the ceiling frames by R0.5 more than the <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_9aa843ab-a32c-4d1a-b712-8fb10e99840b" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> derived from (1); or</li><li>adding a continuous ceiling insulation layer with a minimum <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_c3e8f267-9faf-44b8-8ee6-ce0385000a7f" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> of R0.13 above or below the ceiling joists or the bottom chords of the trusses; or</li><li>achieving the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_e320f89d-7ed5-48e8-b2e7-dd51d6e3b50a" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref> ceiling <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_89aede63-61af-457d-9a41-298638f947f3" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> derived from (1) by stacking two layers of insulation immediately on top of each other, such that the top layer is orientated to cover the ceiling joists or bottom chord of the trusses and has an <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_057083a4-1ccb-44c0-a435-ef17c73ca5bf" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> of at least R0.5; or</li></ol></li><li id="_af74472b-31e4-4890-b5c9-98ba1b9e18f3">for a flat, skillion or cathedral roof—<ol><li>achieving the <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1490_25.4.0.xml#_5a8cb42e-a549-40fa-a685-3422c624c5b7" id="_652d84c6-a584-460d-99ab-180823d17655" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">Total R-Value</xref> in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6287_0.20.0.xml#_891ecf3d-816f-4cf1-aac4-7aac94e96209" id="_1cf2c8a4-1948-4d9d-b496-96c7dd794642" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D7t</xref>, calculated using a method that accounts for the effects of thermal bridging; or</li><li>complying with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6293_0.23.0.xml#_d078b8bb-6900-4b26-8489-e55875f1be0d" id="_c6e52884-4509-4469-a0b7-1828109f0334" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D7u</xref>.</li></ol></li></ol></subclause><subclause id="_aa2d585c-a2a0-46ce-8196-36970939a379" outputclass="subclause"><title id="_11913225-5799-46a1-bba9-09bdbec20368">SubClause</title><num>4</num><p>Where <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/3291_2.50.0.xml#_7d1c4dad-77d9-4ab4-929f-1fe3c3718b2d" id="_990b9fc2-5cea-4d64-98c7-43c5e565f9e2" referencetype="Text" scope="local" synctargettext="false" type="subclause">F8D5(1)</xref> applies, continuous insulation placed above the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_7db0b1a0-a636-4085-9b22-e9ffbaeec364" id="_842c1ae6-1e71-4203-9ade-aa0171bb4bea" referencetype="Text" scope="local" synctargettext="false" type="glossterm">primary insulation layer</xref> to mitigate thermal bridging must have a <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6175_0.10.0.xml#_a8b17dfe-243d-477e-9d64-add1432fcdb4" id="_08c14576-bb9b-4f7e-8d01-e683c8482d8e" referencetype="Text" scope="local" synctargettext="false" type="glossterm">vapour permeance</xref> of not less than that of the <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_7db0b1a0-a636-4085-9b22-e9ffbaeec364" id="_4b7debf8-879d-45ae-9daf-0f3ab31bec8e" referencetype="Text" scope="local" synctargettext="false" type="glossterm">primary insulation layer</xref>.</p></subclause><subclause id="_26f57b2b-0ba5-4815-be41-906d410af6fc" outputclass="subclause"><title id="_02bc8c98-8b68-40fb-aa37-881e44c20e5a">SubClause</title><num>5</num><p>Where, for operational or safety reasons, the area of ceiling insulation <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_55f255d1-9200-4bfb-bec0-d6b1fcc32120" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref> is reduced, the loss of insulation must be compensated for in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6280_0.15.0.xml#_c80e7a28-ac85-46c2-a6fe-99bfec13d480" id="_56e6d225-e563-42b5-ae85-10a584f21966" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D7w</xref>.</p></subclause><subclause id="_801b840e-4f79-4a64-a9a9-9ee039f11460" outputclass="subclause"><title id="_0cf941ea-02f2-4c3e-b066-3dc594c4a6f1">SubClause</title><num>6</num><p>Where the ceiling insulation <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_8efeecba-993c-4f79-a055-a1944a13ab78" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref> by (1) to (5) has an <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_cf3886c4-1bc0-4119-8cf0-3b9c7a8278b2" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref>—</p><ol outputclass="alpha"><li id="_a040b374-38f1-45ae-9b5f-43c6f27f466d">greater than R3.0 and less than or equal to R4.5, it may be reduced to R3.0 within 450 mm of an <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1267_2.3.0.xml#_5b9d76ce-afd0-41cf-983f-5409851148dc" id="_f74f1c31-0d93-4c9a-b5d7-181d3d1f19e2" referencetype="Text" scope="local" synctargettext="false" type="glossterm">external wall</xref>; or</li><li id="_0aa7a1aa-830d-49ae-a28f-d6a93a2ce41b">greater than R4.5, it may be reduced to R3.0 within 450 mm of an <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1267_2.3.0.xml#_5b9d76ce-afd0-41cf-983f-5409851148dc" id="_1be2971c-8c03-47eb-bef7-024fcb491878" referencetype="Text" scope="local" synctargettext="false" type="glossterm">external wall</xref>, provided all other <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_ef2a4db1-af22-4fe5-bf50-1dd41574fd49" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref> ceiling insulation is increased by R0.5.</li></ol></subclause><subclause id="_61c604cc-c744-4b87-9b3e-5081d40eb9c9" outputclass="subclause"><title id="_161bd700-4403-4b35-bb39-3eecb4bd576d">SubClause</title><num>7</num><p>The requirements of (1) to (6) do not apply to roofs constructed using insulated sandwich panels.</p></subclause><subclause id="_af5dc9f0-f61f-4335-adac-e7d3f0b7649f" outputclass="subclause"><title id="_82694bed-4a39-4723-b763-7a695fb911a9">SubClause</title><num>8</num><p>Roofs constructed using insulated sandwich panels must achieve the minimum <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1490_25.4.0.xml#_bf26e61b-dbc1-4c09-b8be-ac8d936c0ac9" id="_13605ff5-6eb3-4a89-a8f6-e2c8d90dbcd7" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Total R-Value</xref> in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7202_0.14.0.xml#_9a7c231a-af03-451f-805a-eb205f64a4fc" id="_6154ff69-87d8-4e1b-9625-b0ce487872bd" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table J3D7x</xref>.</p></subclause><subclause id="_5926678a-db35-4d6e-bb85-0e959826ed2b" outputclass="subclause"><title id="_c95c798f-a6c3-455d-b612-1df2fc6dd8be">SubClause</title><num>9</num><p>In <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_ecb004db-9453-43a0-a93a-d683b406aa70" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 1 to 5, the solar absorptance of the upper surface of a roof must not be more than 0.64.</p></subclause><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6259_0.15.0.xml" graph="None" id="_193b9818-e743-40b1-b622-966347f0f340"><num/><title id="_2c18f345-6438-4095-9454-7975dd4554a8"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6260_0.33.0.xml" graph="None" id="_5d63432b-6cdf-4052-bd1f-f685b168963f"><num/><title id="_7a5745a4-cf67-4701-b711-92a54f6fd2bd"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6261_0.20.0.xml" graph="None" id="_326aacb3-2d3b-494d-8600-8446040c8e5d"><num/><title id="_99fe2c99-dd23-465e-9239-562ce98b9ee7"/></table-reference><table-reference author="Brandon Kiem" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6262_0.12.0.xml" dateTime="2022-03-29T08:47:58" graph="None" id="_a6a4c83b-0da0-49d6-8986-b682c3622cfd" type="insert"><num/><title id="_364b608c-514b-4d62-90b9-b23364402e1a"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6263_0.19.0.xml" graph="None" id="_4ec953c1-5c59-4e53-ad25-7ac38467102b"><num/><title id="_d1f4a0b1-14a0-4f48-9c82-47ddfd2cf3a3"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6264_0.19.0.xml" graph="None" id="_64f563df-4e58-4419-9f2e-1db60bbc25fe"><num/><title id="_924b3a05-7a46-4d0c-98b8-fc9632d6a0cb"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6265_0.10.0.xml" graph="None" id="_d190d215-91d8-44e5-8c4b-7ee0b1c913db"><num/><title id="_bfbf0360-9608-4427-89fb-c80835bc6088"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6266_0.32.0.xml" graph="None" id="_cca4dec5-da74-4276-af12-3d4ceb065e2d"><num/><title id="_fa7292db-7e85-4b65-8e9b-cb66807e4c5a"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6267_0.20.0.xml" graph="None" id="_e929de14-cf70-4d3e-8e84-22379e0ae8f8"><num/><title id="_7bc98c55-dc5b-42bf-bc52-136c204020fa"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6268_0.11.0.xml" graph="None" id="_4a3b991b-7eaa-4307-87ff-dd24f194dd51"><num/><title id="_9d275448-b2d9-4967-a0e8-b01861c7eddf"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6270_0.17.0.xml" graph="None" id="_c94c743d-6fb8-4a6e-b898-2da0baf3644d"><num/><title id="_70e00e13-d795-4c37-a16b-b625c5464fd3"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6271_0.12.0.xml" graph="None" id="_5757b994-46a0-456c-85e6-bba1ebf8391e"><num/><title id="_a7933592-aab4-41cb-8069-ebc7f6da02fa"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6273_0.11.0.xml" graph="None" id="_deada076-ebc0-4652-a29e-35cda3b46182"><num/><title id="_9bc40012-fed6-4835-8755-12a9d18b8236"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6274_0.22.0.xml" graph="None" id="_49c46bc9-88a8-4075-8c9b-7b4b985791d8"><num/><title id="_d6c47424-be83-48fd-9666-8a48195c5a25"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6275_0.11.0.xml" graph="None" id="_bf266037-5a29-4c2d-9858-1403ac8df5c7"><num/><title id="_49c7067a-f18a-4b76-865e-e5bcc7c04b5a"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6276_0.14.0.xml" graph="None" id="_4772e33e-f83d-4f00-a2ef-1f8a4bae48b7"><num/><title id="_42198ecb-84b2-4e6c-af66-1a15aa7fa829"/></table-reference><table-reference author="Brandon Kiem" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7405_0.5.0.xml" dateTime="2022-04-22T12:29:55" graph="None" id="_8e636821-4d94-491f-8a30-7a82597c1e58" type="insert"><num/><title id="_e523c22f-420a-460f-a92f-ac865cd1b4e6"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6278_0.14.0.xml" graph="None" id="_9b28c94d-30f5-4bce-978b-6baf04f52036"><num/><title id="_8f836eaf-31d1-4db7-a266-cc9b721c9e3d"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6281_0.18.0.xml" graph="None" id="_5bed239d-d208-4a8a-9aa6-7798c64c3eb4"><num/><title id="_e080a4da-c4eb-4778-be06-c6433ad76932"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6287_0.20.0.xml" graph="None" id="_891ecf3d-816f-4cf1-aac4-7aac94e96209"><num/><title id="_c1d5cb02-4464-489e-8759-d72b86fe4006"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6293_0.23.0.xml" graph="None" id="_d078b8bb-6900-4b26-8489-e55875f1be0d"><num/><title id="_8b3c2d33-62d0-4be9-87de-8b7463d38d1e"/></table-reference><table-reference author="Brandon Kiem" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7388_0.4.0.xml" dateTime="2022-04-12T15:54:25" graph="None" id="_6eea30e3-9800-452b-8739-77f06eea1cb5" type="insert"><num/><title id="_1cdb93dd-f1fc-417f-8005-c68c8b8d57c6"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6280_0.15.0.xml" graph="None" id="_c80e7a28-ac85-46c2-a6fe-99bfec13d480" orientation="Landscape"><num/><title id="_37e3eaaa-3c14-4ecc-b926-00611eefce81"/></table-reference><table-reference conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7202_0.14.0.xml" graph="None" id="_9a7c231a-af03-451f-805a-eb205f64a4fc"><num/><title id="_3324075d-b489-4991-9b5a-e9dbe4c41b82"/></table-reference></clause>