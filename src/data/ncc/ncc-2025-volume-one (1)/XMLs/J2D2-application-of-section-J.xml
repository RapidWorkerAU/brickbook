t" scope="local" synctargettext="false" type="ncc-clause">J1P4</xref> is satisfied by complying with <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6192_0.42.0.xml#_f6d1068d-44c1-453e-8452-4712d8e4ae0f" id="_2f1a5e8a-ac59-4736-9e14-b18ad972ee4f" referencetype="Text" scope="local" synctargettext="false" type="subclause">J9D4(1)</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6192_0.42.0.xml#_c491811f-e93d-45c7-957d-abc23ae822ab" id="_930d4b84-0182-4821-a24f-a7d0dc01066c" referencetype="Text" scope="local" synctargettext="false" type="subclause">J9D4(2)</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6194_0.27.0.xml#_d73fa997-f7d8-457e-86b8-bcd1fca6b57d" id="_c1e4f5c1-624f-45d9-84e9-4d20b018264c" referencetype="Text" scope="local" synctargettext="false" type="subclause">J9D5(1)</xref>.</p></subclause></clause>