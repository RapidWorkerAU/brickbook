<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_c77e07de-caa5-4baf-b620-3807f1f13fe1" outputclass="ncc-clause"><sptc>C2P3</sptc><title id="_4c07c61a-6878-4945-93b2-262b302f5e09">Access</title><archive-num>2019: CP2.1</archive-num><subclause id="_b4116904-7bb6-4fa9-b451-80df0dd4bedb" outputclass="subclause"><title id="_9f9dfdbb-4613-4b66-b9f6-15b8ac0e1958">SubClause</title><num>1</num><p>Access must be provided to components of a sanitary <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1249_0.8.0.xml#_25307451-c7e1-4167-b4de-e5a1af26694c" id="_e8a08af4-9bb0-412e-afde-f75a3282af1a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drainage</xref> system that require maintenance or replacement including mechanical devices, controls and for clearing <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1209_1.2.0.xml#_417d94d8-f254-4788-9a14-c4c5da89daa6" id="_0158c948-b1bd-408a-a61b-d8c3ba2f9db4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">blockages</xref>.</p></subclause><callout id="_ef695040-5663-4b7b-b502-2bcb812eedf7"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door, or similar obstruction.</p></callout></clause>