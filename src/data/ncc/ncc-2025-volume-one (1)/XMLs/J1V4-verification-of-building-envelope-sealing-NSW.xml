8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_ee9142c5-1177-45a3-aa7c-6ed95de7d244" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 1, 7 and 8, 5 m³/hr.m² at 50 Pa reference pressure; or</li><li id="_a8c05bcd-0e22-4f1c-96d5-d505f452c3de">for a Class 3 or 9c building, or a Class 9a <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1512_27.0.0.xml#_d1b612a5-df98-4406-ba1e-237f837e1061" id="_cac4612a-d36f-4042-b1d5-c52adef221a9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">ward area</xref> in <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_76c4d748-27f4-4c3b-a84c-1a1421c9947d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 1, 3, 4, 6, 7 and 8, 5 m³/hr.m² at 50 Pa reference pressure.</li></ol></subclause></clause>