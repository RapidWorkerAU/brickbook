<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" Buddy_ElementBookmark="Xpress_Internal_2" id="_fdbdac58-ed66-429d-b469-82c4af0b737f" outputclass="ncc-clause"><sptc Buddy_ElementBookmark="Xpress_Internal_3">F8D6</sptc><title Buddy_ElementBookmark="Xpress_Internal_4" id="_2aa55db3-a812-4ec2-b3b8-8565b34a62a8">Ventilation of a roof space with the primary insulation layer parallel to the roof plane</title><archive-num Buddy_ElementBookmark="Xpress_Internal_5"/><subclause id="_b649170d-4675-42f4-bc35-07c53cc84ccc" outputclass="subclause"><title Buddy_ElementBookmark="Xpress_Internal_6" id="_97bc89e3-294d-4026-b448-cb3cd7395d2a">SubClause</title><num Buddy_ElementBookmark="Xpress_Internal_7">1</num><p Buddy_ElementBookmark="Xpress_Internal_8">In <xref Buddy_EmphasisBookmark="Emphasis_1_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_5a0ac48c-87b2-4061-8635-5c516ce483bf" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 6, 7 and 8, a roof system with the <xref Buddy_EmphasisBookmark="Emphasis_2_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_e43df641-2c5c-44ea-9ad2-17892e868c90" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref> installed parallel to the roof plane must have a roof space that—</p><ol outputclass="alpha"><li Buddy_ElementBookmark="Xpress_Internal_9" Buddy_ListStyle="List Number (XA)_64892347_7a72_4ce1_908f_bd3f82724bb7" id="_ed8c73bf-846e-44ac-aac4-c665362c1f91">is located immediately above—<ol><li Buddy_ElementBookmark="Xpress_Internal_10" Buddy_ListStyle="List Number 2 (XA)_e3b1c0b6_f17d_44f6_a877_680ad691523a">the <xref Buddy_EmphasisBookmark="Emphasis_3_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_1eda7b7e-90ed-4092-b5eb-e6f73168b9c9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref>; or</li><li Buddy_ElementBookmark="Xpress_Internal_11" Buddy_ListStyle="List Number 2 (XA)_e3b1c0b6_f17d_44f6_a877_680ad691523a">any <xref Buddy_EmphasisBookmark="Emphasis_4_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10130_0.7.0.xml#_e53cf170-3a1e-49b9-942d-76571f407ccc" id="_223099d4-1584-4220-a98e-e9e8705632c4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">control layer</xref> installed immediately above the <xref Buddy_EmphasisBookmark="Emphasis_5_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_4b7631ce-f058-4ed3-a756-b5fe8085bbb0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref>; and</li></ol></li><li Buddy_ElementBookmark="Xpress_Internal_12" Buddy_ListStyle="List Number (XA)_64892347_7a72_4ce1_908f_bd3f82724bb7" id="_5d6473ec-79b6-45e9-8e37-e1ef53e86488">is not obstructed by insulation; and</li><li Buddy_ElementBookmark="Xpress_Internal_13" Buddy_ListStyle="List Number (XA)_64892347_7a72_4ce1_908f_bd3f82724bb7" id="_2d22d3d9-330c-4467-a87f-1ec9f9113a69">has a height not less than 18 mm, as measured perpendicular to the plane of the roof; and</li><li id="_5d387a76-89b9-40ec-b45b-11245ce7b37e">for roofs less than 10 m<sup id="_d02731c1-f1bd-454e-9186-d82ea6d3418d">2</sup>, is ventilated to <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1388_0.4.0.xml#_411d1010-9a7f-494c-af78-cf1ba1523530" id="_004b6f7e-7ad0-4d7c-af21-0a745370e2ce" referencetype="Text" scope="local" synctargettext="false" type="glossterm">outdoor air</xref> through openings not less than—<ol><li>7,000 mm<sup id="_375955e6-f768-4d0a-8166-3057e6450103">2</sup>/m provided at eaves or low level; and</li><li>5,000 mm<sup id="_d3542d43-9a0f-4fc0-bb65-4bb81a579cfe">2</sup>/m at the high level or ridge; and</li></ol></li><li id="_31054c6a-4fb4-4450-a8e4-ef0f5f825019">for all other roofs, is ventilated to <xref format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1388_0.4.0.xml#_411d1010-9a7f-494c-af78-cf1ba1523530" id="_8dbea810-78b8-4c99-96eb-6a5c587eb401" referencetype="Text" scope="local" synctargettext="false" type="glossterm">outdoor air</xref> through openings not less than—<ol><li>20,000 mm<sup id="_6a483604-f3b7-43cb-a8f9-6953fc7536c4">2</sup>/m provided at the eaves or low level; and</li><li>5,000 mm<sup id="_e9a7eb01-151e-4893-81ba-f9696bd401f7">2</sup>/m provided at the high level or ridge.</li></ol></li></ol></subclause><subclause id="_a45d115c-1ec6-42fe-8d04-e0cb3716292f" outputclass="subclause"><title Buddy_ElementBookmark="Xpress_Internal_20" id="_147e6bfe-e1fd-45d7-924e-3e06564d646b">SubClause</title><num Buddy_ElementBookmark="Xpress_Internal_21">2</num><p Buddy_ElementBookmark="Xpress_Internal_22">Where a <xref Buddy_EmphasisBookmark="Emphasis_11_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10130_0.7.0.xml#_e53cf170-3a1e-49b9-942d-76571f407ccc" id="_e24319f0-e20f-4875-957f-6936cec71e51" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">control layer</xref> is installed immediately above the <xref Buddy_EmphasisBookmark="Emphasis_12_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_f8918443-e5e8-462e-856e-0cac3a62cc5e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref> in <xref Buddy_EmphasisBookmark="Emphasis_13_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_83ff7277-84df-4446-ba61-a29bd8dc380f" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref><xref Buddy_EmphasisBookmark="Emphasis_14_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_83ff7277-84df-4446-ba61-a29bd8dc380f" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">s</xref> 6, 7 and 8, it must have a <xref Buddy_EmphasisBookmark="Emphasis_15_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/6175_0.10.0.xml#_6865163b-ba99-4d48-9e9b-a76b4641be1c" id="_203e1f54-444f-48db-961e-0227802429d2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">vapour permeance</xref> of not less than 1.14 μg/N.s. </p></subclause><subclause id="_7f49aefd-91fe-4e91-9012-df986cee3dd6" outputclass="subclause"><title Buddy_ElementBookmark="Xpress_Internal_23" id="_6ad29750-f6e0-4c45-a4e2-1ba9925c4b28">SubClause</title><num Buddy_ElementBookmark="Xpress_Internal_24">3</num><p Buddy_ElementBookmark="Xpress_Internal_25">The requirements of (1) do not apply to a—</p><ol outputclass="alpha"><li Buddy_ElementBookmark="Xpress_Internal_26" Buddy_ListStyle="List Number (XA)_0c4aae17_fffd_4700_b1ab_c09256fdf09b" id="_59722f02-9380-429d-87f0-634c8e52e90e">concrete roof; or</li><li Buddy_ElementBookmark="Xpress_Internal_27" Buddy_ListStyle="List Number (XA)_0c4aae17_fffd_4700_b1ab_c09256fdf09b" id="_5c56ed5c-dff5-4003-9cd9-dc00a79d8068">roof that is made of insulated sandwich panels with or without an additional ceiling linings; or</li><li Buddy_ElementBookmark="Xpress_Internal_28" Buddy_ListStyle="List Number (XA)_0c4aae17_fffd_4700_b1ab_c09256fdf09b" id="_fc130945-d428-443f-9300-302e391176a0">roof that is subject to Bushfire Attack Level FZ requirement in accordance with AS 3959; or</li><li Buddy_ElementBookmark="Xpress_Internal_29" Buddy_ListStyle="List Number (XA)_0c4aae17_fffd_4700_b1ab_c09256fdf09b" id="_56a8fd4b-09a6-4715-a56a-e55144536a31">tiled roof without a <xref Buddy_EmphasisBookmark="Emphasis_16_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10130_0.7.0.xml#_e53cf170-3a1e-49b9-942d-76571f407ccc" id="_0a1bcf83-646f-4f19-a584-d98eb4b13f8d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">control layer</xref> located above the <xref Buddy_EmphasisBookmark="Emphasis_17_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_22d73533-4320-412f-aa99-248f8ee31ec4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref>.</li></ol></subclause><callout Buddy_ElementBookmark="Xpress_Internal_30" id="_b5386bdb-cde2-46fe-9e71-66cc66ee5498"><callout-type Buddy_ElementBookmark="Xpress_Internal_31" ncc-info-type="info"/><p Buddy_ElementBookmark="Xpress_Internal_32"><xref Buddy_EmphasisBookmark="Emphasis_18_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10141_0.9.0.xml#_bebd1dd9-263f-46af-baff-d5b0f967d53c" id="_e3385c02-e6b0-4a37-ae71-99d9e8560eb3" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Explanatory Figure F8D6a</xref> is an example of when a roof comprises of one roof space with multiple roof types, combining requirements for <xref Buddy_EmphasisBookmark="Emphasis_19_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/3291_2.50.0.xml#_9991e3ce-adab-4e0b-8fe4-123ce4a00ed8" id="_66ea3694-d808-4821-bdb2-675fd4fe0806" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">F8D5</xref> and <xref Buddy_EmphasisBookmark="Emphasis_20_xref" format="dita" href="#_fdbdac58-ed66-429d-b469-82c4af0b737f" id="_bbef43f5-e397-4ef3-a437-f0c0a809d118" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">F8D6</xref>. In this instance the low level ventilation requirements for each roof type are applicable, however, only one high level opening is required at the ridge as the lower roof opening is discharging into the larger roof space.</p><p Buddy_ElementBookmark="Xpress_Internal_33"><xref Buddy_EmphasisBookmark="Emphasis_21_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10142_0.8.0.xml#_e4634ab3-8193-410a-b2b1-d3bb2fe76f1c" id="_724e994a-2caf-418f-9007-cf864d6395a6" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Explanatory Figure F8D6b</xref> is an example of a roof type complying with F8D6(1)(a)(i), where the roof space is above the <xref Buddy_EmphasisBookmark="Emphasis_22_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_aafefcad-96be-42d4-823f-f1acce75ca2b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref>.</p><p Buddy_ElementBookmark="Xpress_Internal_34"><xref Buddy_EmphasisBookmark="Emphasis_23_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10143_0.9.0.xml#_8aaf73fb-4822-4bdc-8e36-8caedc755205" id="_f525bd8d-d305-43e4-ba39-e201af4f2abc" referencetype="Text" scope="local" synctargettext="false" type="image-reference">Explanatory Figure F8D6c</xref> is an example of a roof type complying with F8D6(1)(a)(ii), where the roof space is above the <xref Buddy_EmphasisBookmark="Emphasis_24_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10130_0.7.0.xml#_e53cf170-3a1e-49b9-942d-76571f407ccc" id="_44c1d2c5-d603-44cc-b32e-f3c2267880c1" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">control layer</xref> installed immediately above the <xref Buddy_EmphasisBookmark="Emphasis_25_xref" format="dita" href="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/7180_0.6.0.xml#_e0128ee3-46f3-45d2-9b1b-e069b935fd58" id="_87c46f6f-43c8-4712-86c6-e01d4bfdedf0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">primary insulation layer</xref>.</p><image-reference Buddy_ElementBookmark="Xpress_Internal_35" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10141_0.9.0.xml" id="_bebd1dd9-263f-46af-baff-d5b0f967d53c"><num/><title id="_f4791749-e83b-4fbe-9a25-0b999ff4421b"/></image-reference><image-reference Buddy_ElementBookmark="Xpress_Internal_41" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10142_0.8.0.xml" id="_e4634ab3-8193-410a-b2b1-d3bb2fe76f1c"><num/><title id="_fa0e70e8-76f7-483f-b310-916db0625c8d"/></image-reference></callout><image-reference Buddy_ElementBookmark="Xpress_Internal_48" conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/10143_0.9.0.xml" id="_8aaf73fb-4822-4bdc-8e36-8caedc755205"><num/><title id="_b5b7d083-7aab-428b-8458-ca74db99e578"/></image-reference></clause>