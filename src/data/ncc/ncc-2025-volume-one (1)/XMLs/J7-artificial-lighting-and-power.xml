<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-part" ?><part xmlns:xlink="https://ncc.abcb.gov.au/ncc-online/NCC/2019-A1/NCC-2019-Volume-One-Amendment-1/Schedule-3-Definitions/Schedule-3-Definitions/Definitions?inlineLink=ID4a5c07a9-ca33-4eb7-b6b6-eaef05011da0" xmlns:xt="urn:xpressauthor:trackchanges" id="_e4bad8ff-4479-4285-a091-145ca2e85197" outputclass="ncc-part"><num>J7</num><title id="_8f0be491-535c-4389-8111-fce48ed5f6c8">Artificial lighting and power</title><part-variation deleted-text="For a Class 2 building and Class 4 part of a building, Section J is replaced with Section J of BCA 2009 (without NT variation). For Class 3 and Class 5-9 buildings, Section J of NCC 2025 does not apply and is replaced with Section J of NCC 2019 (without NT variation)." variation="NT" variation-type="DELETE">NT DELETE Part</part-variation><intro-part id="_16093b75-5912-4e07-9746-d51a3386a379"><p>This Part contains Deemed-to-Satisfy Provisions for compliance with Part J1. It sets out provisions for the design and configuration of artificial lighting and power, boiling and chilled water units, lifts and escalators and moving walkways.</p></intro-part><subtopic id="_d2ab3341-c373-4ca8-9c35-94a0e055aeda" subtopic-type="provision"><clauseref id="_da4e4cfe-26b2-4a35-a53c-41fc8ec6ac85" outputclass="clausref-ncc"><clause conref="/tmp/QppServer/Publishing/d5440ff9-b49a-4154-8539-afc815034863/3455_4.17.0.xml" id="_d1f80bca-194a-47cd-af05-7227e91f25b6" outputclass="ncc-clause"><meta xmlns:inv="urn:xpressauthor:xpressdocument" inv:access="external"><facet building="Class 1a" inv:access="external"/><facet building="Class 1b" inv:access="external"/><facet building="Class 10a" inv:access="external"/><facet building="Class 10b" inv:access="external"/><facet building="Class 10c" inv:access="external"/></meta><sptc/><title id="_3fe7dcc0-b4d4-46c6-9e9b-edd1138d559d"/></clause></clauseref><clauseref id="_110558c6-a4f1-47c4-abfd-406074b05169" outputclass="clausref-n