<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_c0047430-5f30-4e97-bf3f-71614376a6cf" outputclass="ncc-clause" variation="NT"><sptc>13.7.3</sptc><title id="_6bbda14b-79b2-4cd3-b79c-98b15adac1ed">Central heating water piping</title><archive-num>New for 2022</archive-num><subclause id="_127cc146-4c2b-4352-b55e-96fc006a9bb5" outputclass="subclause"><title id="_83e2abb4-7371-42a2-b94c-7b67709b28e7">SubClause</title><num>1</num><p>Central heating water <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_c2a4355b-831c-4629-a13d-2c18c2a4ae92" id="_419eb280-4336-4a9b-b3d5-2279367525bf" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="glossterm">piping</xref> that is not within a <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1225_1.8.0.xml#_6f4c27ea-b6b3-468c-9ff4-72d533d9d0a2" id="_7af17b57-2dfe-41f2-9258-3f91d7cda9d8" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="glossterm">conditioned space</xref> must be thermally insulated to achieve the minimum <xref xmlns:inv="urn:xpressauthor:xpressdocument" xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1490_25.4.0.xml#_5a8cb42e-a549-40fa-a685-3422c624c5b7" id="_12fc93b9-d62a-4536-93ea-9dca3ed73ed8" inv:access="external" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">Total R-Value</xref> of 0.6.</p></subclause><subclause id="_e2eb007d-2e05-46fd-9dc6-316bf46f63a8" outputclass="subclause"><title id="_3bd0099a-6e02-4d90-8bfb-fe02fe72a5c7">SubClause</title><num>2</num><p>Internal <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_c2a4355b-831c-4629-a13d-2c18c2a4ae92" id="_d47dcb9d-feeb-4917-8571-140394eda279" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="glossterm">piping</xref> including—</p><ol outputclass="alpha"><li id="_6f4e5669-82ec-4304-92a7-f529986c02e3">flow and return <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_c2a4355b-831c-4629-a13d-2c18c2a4ae92" id="_d77b77aa-1eda-4407-89a9-4a5213c1aeba" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="glossterm">piping</xref> that is—<ol><li>within an unventilated wall space; or</li><li>within an internal floor between storeys; or</li><li>between ceiling insulation and a ceiling; and </li></ol></li><li id="_672ea989-f768-49ee-a275-b6023653fe72">heated water piping encased in a concrete floor slab (except that which is part of a floor heating system), must in all <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_58b93826-12bc-41ad-ab0d-bd103756bdca" id="_73dbc437-4a5f-4ca3-9ea6-a58f1112eae7" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="glossterm">climate zones</xref>, have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_b53de49e-fb07-4aaf-a83c-7beabf339515" inv:access="external" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> of 0.4. </li></ol></subclause><subclause id="_381c42c8-5a6f-4deb-b233-4bd8e3ec34a5" outputclass="subclause"><title id="_e8a5fbc5-82f0-40e7-8aca-cd859cb1bdba">SubClause</title><num>3</num><p>All <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_d1bf7f51-e5f6-4d3d-bc86-0999748c656a" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">piping</xref> located outside a building, or within a ventilated wall space, subfloor or roof space must have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_7530889f-05da-41f5-b20e-bd1abef716c5" inv:access="external" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref> of 0.6. </p></subclause><callout id="_22a56a6f-5e88-4a43-b386-7aa348e5f172"><callout-type ncc-info-type="info"/><ul><li>The insulation levels in <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7697_0.2.0.xml#_c4ac98d1-e418-4fd8-9c36-09d1b03b60c1" id="_90212612-25c9-4990-b4a0-77f00ec80ac1" referencetype="Text" scope="local" synctargettext="false" type="table-reference">NT Explanatory Table 13.7.3</xref> are typical examples of materials that can be used to insulate central heating water <xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_9d38a704-f644-4da7-9e05-cf8ba88ff44f" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref>. Other methods are available for meeting the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1490_25.4.0.xml#_5a8cb42e-a549-40fa-a685-3422c624c5b7" id="_d84fd0da-0476-4801-8d42-c5bd8843511e" referencetype="Text" scope="local" synctargettext="false" type="glossterm">Total R-Values</xref> <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_76772210-d903-451d-8805-e71138b4bf5a" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref>. </li><li><xref xmlns:inv="urn:xpressauthor:xpressdocument" xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_c2a4355b-831c-4629-a13d-2c18c2a4ae92" id="_99c749ac-69f0-4ebf-8925-d6f4c871d0f5" inv:access="external" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">Piping</xref> within a timber member, such as that passing through a wall stud, is considered to have sufficient insulation.<table-reference conref="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7697_0.2.0.xml" graph="None" id="_c4ac98d1-e418-4fd8-9c36-09d1b03b60c1" variation="NT"><num>13.7.3 (explanatory)</num><title id="_52381afa-f312-4fb1-8f2d-7c6913468d45">R-Value of the insulation used for smaller diameter piping</title><table id="_0bb616c7-0da6-415b-9bd5-4b765f8ab940" keycol="1"><tgroup cols="2"><colspec colname="002" colnum="1" colwidth="216.00*"/><colspec colname="003" colnum="2" colwidth="216.00*"/><thead><row><entry>Insulation</entry><entry><xref xmlns:qxa="urn:schemas-quark-com:xmlauthor" format="dita" href="ERROR_IN_RESOLVING_URI:r-value.xml#_f438bdfd-6adb-43c4-b342-7b1656af23c4" id="_518ab565-bb96-4500-b007-6602c6c3e32e" qxa:read-only="true" referencetype="Text" scope="local" synctargettext="true" type="glossterm">R-Value</xref></entry></row></thead><tbody><row><entry>9 mm of closed cell polymer</entry><entry>0.4</entry></row><row><entry>13 mm of closed cell polymer</entry><entry>0.6</entry></row><row><entry>19 mm of closed cell polymer</entry><entry>0.9</entry></row><row><entry>25 mm of closed cell polymer</entry><entry>1.3</entry></row><row><entry>25 mm of glasswool</entry><entry>1.3</entry></row></tbody></tgroup></table></table-reference></li></ul></callout></clause>