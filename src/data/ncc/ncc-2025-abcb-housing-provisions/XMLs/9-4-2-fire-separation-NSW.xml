<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause"?><clause id="_7bb14f20-592b-400c-9d88-2ba6ab1012a2" outputclass="ncc-clause" variation="NSW"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>9.4.1</sptc><title id="_ec80e7f8-e76e-418f-9f02-b14afe083440">Fire separation</title><archive-num>2019: NSW 1.1.1</archive-num><subclause id="_b717b118-a0c3-4562-b289-d29af484eac8" outputclass="subclause"><title id="_81ae9707-8540-4f72-a8b2-c1c8b2e1d269">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_73f7a8c5-a894-4b10-b0d0-714cc731151d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> must be separated from a non-associated <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_69f1fd10-bf67-4e0d-b549-2aed84c932cd" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garage</xref> by a floor complying with <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7000_0.7.0.xml#_e9f2be4a-924e-4658-959d-befa24825186" id="_c9adde10-61f4-4192-8b1a-27ddccc5ed37" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW 9.4.2</xref>.</p></subclause><subclause id="_85a5105f-9a1b-419e-89b9-17ced1649cae" outputclass="subclause"><title id="_2775f8f9-e3b7-4b20-abcf-4167800eb689">SubClause</title><num>2</num><p>Where a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_729ce9e6-8b6e-4ffe-a050-86c643275c15" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> is served by an internal stair, the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_2110b873-7861-480a-ac1b-46f3283f57f9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> must be separated from a non-associated <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_98cffb9f-9868-4b56-bb8f-034ad18e8060" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garage</xref> by a wall complying with <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7001_0.11.0.xml#_2b616198-57f3-4671-945e-9e1c0c192864" id="_c6fd7b68-6c2a-4763-a2c6-c0fb53ae9259" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW 9.4.3</xref>.</p></subclause><subclause id="_618dd0d5-1137-446c-8382-aec8280caa5c" outputclass="subclause"><title id="_78880cf1-ac53-485a-acbf-65efdba1cad1">SubClause</title><num>3</num><p>Where a <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_105a2be2-92f3-4b12-a037-8e90efe42d26" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> is located above both associated and non-associated <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_5960cde4-2998-4860-ae42-e761d67c7f7f" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garages</xref>—</p><ol outputclass="alpha"><li id="_d08358e4-a2b0-4ded-9aa4-6ef8dd982b6a">in addition to a floor <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1432_4.0.0.xml#_af6fde9f-147d-4782-8b85-42044e80fd42" id="_b05e644e-1c76-4247-a2e9-9f616a90b329" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">required</xref> by (1), the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_744828bc-d6c8-4775-8dc9-321b5ea2a7e4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garages</xref> must be separated with a wall complying with <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7001_0.11.0.xml#_2b616198-57f3-4671-945e-9e1c0c192864" id="_d1ba2346-da5b-48c2-9b54-f2b42f58ba19" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW 9.4.3</xref>; or</li><li id="_50f28bc6-4cc5-4e0b-b7a7-8ee91dd16d0f">where a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_bc8fc570-d6ca-49fc-92f1-eb47d8a95ad1" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> is not served by an internal stair, the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/6998_0.2.0.xml#_702eed44-bee6-4933-9140-23047aa61825" id="_14bfece1-25b0-46f5-b1d2-8e26883696ca" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">garage top dwelling</xref> may be separated from the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_2f4b6566-afd2-45f5-b16e-59e111a92c36" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garages</xref> by a floor complying with <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/7000_0.7.0.xml#_e9f2be4a-924e-4658-959d-befa24825186" id="_fa1193cf-a10a-4ef0-bdf5-39b70dd74a59" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW 9.4.2</xref>.</li></ol></subclause></clause>