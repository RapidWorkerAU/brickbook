<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_d60e934c-35ea-4f25-b356-712a4747852e" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10c"/></meta><sptc>13.7.3</sptc><title id="_21831d20-1500-46be-9b2d-d0679b745bf9">Central heating water piping</title><archive-num>2019: 3.12.5.2</archive-num><subclause id="_8989b991-9739-487c-a3ab-9f8d85a75820" outputclass="subclause"><title id="_7124cda1-b792-4f3e-8c37-872c32d0b6d7">SubClause</title><num>1</num><p>Central heating water <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_e359df19-4442-4d33-b915-613b9d294166" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> that is not within a <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1225_1.8.0.xml#_26276791-20ad-4404-951f-29b5bff0ff80" id="_00a84298-f28f-42eb-9adb-440bb0413655" inv:access="external" scope="local" type="abcb-glossentry">conditioned space</xref> must be thermally insulated to achieve the minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_19555018-7fda-439e-89cc-2bac2a7637b5" inv:access="external" scope="local" type="abcb-glossentry">R-Values</xref> as set out in (2) to (6).</p></subclause><subclause id="_1911a483-571c-4d50-ae9b-0774989f1fbe" outputclass="subclause"><title id="_7f30f774-de0b-42c8-bd29-a9641dac800f">SubClause</title><num>2</num><p>Internal <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_729b3ed8-d0c4-4103-8a3f-1fb6c3eeeb04" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> including—</p><ol outputclass="alpha"><li id="_95b8c71b-bbf0-4056-ba11-673b0e67cb6f">flow and return <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_90bd9b16-4b15-4b5c-8a4f-3577af3c0289" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> that is—<ol><li>within an unventilated wall space; or</li><li>within an internal floor between storeys; or</li><li>between ceiling insulation and a ceiling; and</li></ol></li><li id="_08cc0669-df3c-4c9a-9c03-f97e9c055891">heated water piping encased within a concrete floor slab (except that which is part of a floor heating system),</li></ol><p>must, in all <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_9f4ddba2-d593-45fb-84f1-492636da98aa" inv:access="external" referredAs="_048ea92f-525b-4294-913f-c009e90bffcb" scope="local" type="abcb-glossentry">climate zones</xref>, have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_238e1d38-44aa-451a-897a-213cb47e9d56" inv:access="external" referredAs="_9b672bc8-f67c-412c-92a4-82fca76dfda7" scope="local" type="abcb-glossentry">R-Value</xref> of 0.4.</p></subclause><subclause id="_1c3faa50-5a63-46f7-bb84-72ece3016c23" outputclass="subclause"><title id="_7d7a0162-3768-4b5d-88e2-2eb7f35cd582">SubClause</title><num>3</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_0f05c05b-66c2-42b0-abec-611de817f4ab" inv:access="external" scope="local" type="abcb-glossentry">Piping</xref> located within a ventilated wall space, an enclosed building subfloor or a roof space, including—</p><ol outputclass="alpha"><li id="_05b54c52-d5bc-44b4-a827-40c6f8597d9c">flow and return <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_ed90e8c3-93e2-401b-8f00-6744a715e7e7" inv:access="external" scope="local" type="abcb-glossentry">piping</xref>; and</li><li id="_64a79c38-d0b6-42cd-acf7-8d42506b4a46">cold water supply <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_24374969-171f-494c-b7c2-64f23eb4e6ec" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> within 500 mm of the connection to the central water heating system; and</li><li id="_aaa3755c-3966-41a2-b2fb-94b25e43369c">relief valve <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_6147a254-2dfd-4373-9c6f-e729a9b2d6f0" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> within 500 mm of the connection to the central water heating system,</li></ol><p>must have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_c1eb4e3f-cb59-4199-90dc-cf3d6c8b4056" inv:access="external" referredAs="_ebdf2009-f1cb-4ec6-8a0c-d75b7023d775" scope="local" type="abcb-glossentry">R-Value</xref> in accordance with (5).</p></subclause><subclause id="_3326b874-ee4e-4091-905c-4679c39a45b7" outputclass="subclause"><title id="_ef5a63bd-67ff-44d9-af19-69717b535128">SubClause</title><num>4</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_3dcb87b6-c7f7-43d7-9152-04fb1ec91b4f" inv:access="external" scope="local" type="abcb-glossentry">Piping</xref> located outside the building or in an unenclosed building subfloor or roof space, including—</p><ol outputclass="alpha"><li id="_3bc9e0a5-86a3-4875-8fdd-973401c3e469">flow and return <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_7649ffda-7c7b-41d6-b9a9-88679e9aff4e" inv:access="external" scope="local" type="abcb-glossentry">piping</xref>; and</li><li id="_41023ba7-6666-4791-932b-a101d3e1f895">cold water supply <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_d3365614-71c6-4f3f-b5b3-685e30776e05" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> within 500 mm of the connection to the central water heating system; and</li><li id="_c2349e1e-94fa-4144-8e2b-d9831664c5db">relief valve <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_575fe1a0-ec34-466d-be53-7ef84edb15d6" inv:access="external" scope="local" type="abcb-glossentry">piping</xref> within 500 mm of the connection to the central water heating system,</li></ol><p>must have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_0311bc91-a039-43d7-9a66-92ebb6277f59" inv:access="external" scope="local" type="abcb-glossentry">R-Value</xref> in accordance with (6).</p></subclause><subclause id="_469db749-ba66-4549-b166-c2e5c53cd7f3" outputclass="subclause"><title id="_4a9813bd-665d-4841-9741-8c95514f8891">SubClause</title><num>5</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_32a1aadc-8a29-4191-ace9-a36c445f8850" inv:access="external" scope="local" type="abcb-glossentry">Piping</xref> referred to in (3) must have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_0c4061b8-6932-4b86-860f-090f0ed63bfb" inv:access="external" scope="local" type="abcb-glossentry">R-Value</xref> of—</p><ol outputclass="alpha"><li id="_a26e48df-8f70-424d-8d0f-5e0709a457ce">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_0ee77691-60ee-46bc-be35-25157b361fe0" inv:access="external" scope="local" type="abcb-glossentry">climate zones</xref> 1, 2, 3 and 5 — 0.6; and</li><li id="_60837f56-85fe-491f-8a7a-fb2af44cfcce">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_0050e037-cafc-4fff-84c4-c849fd0e393d" inv:access="external" scope="local" type="abcb-glossentry">climate zones</xref> 4, 6 and 7 — 0.9; and</li><li id="_f920ba08-fbe3-4133-9dc8-9fda80150396">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_554206c1-80e8-479a-9a9a-6465058938eb" inv:access="external" scope="local" type="abcb-glossentry">climate zone</xref> 8 — 1.3.</li></ol></subclause><subclause id="_00eb51c6-a121-4d42-a811-a124d4fde4f8" outputclass="subclause"><title id="_8662dd8b-3158-43e4-9459-218e961b2b2a">SubClause</title><num>6</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_69e3bfee-13a5-47db-9556-a95eafd1ab67" inv:access="external" scope="local" type="abcb-glossentry">Piping</xref> referred to in (4) must have a minimum material <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_59529ca5-05d0-4a09-ba56-dd3468718162" inv:access="external" scope="local" type="abcb-glossentry">R-Value</xref> of—</p><ol outputclass="alpha"><li id="_22f61ce0-e6aa-4a75-bbf5-1e796adec4f8">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_7e44e2e8-a4ce-43ca-817b-d24321f55a8c" inv:access="external" scope="local" type="abcb-glossentry">climate zones</xref> 1, 2, 3 and 5 — 0.6; and</li><li id="_54c58cc3-e042-4f36-ac8d-1951a4334579">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_cab7768c-9b8a-463f-9e51-ff6298ea3232" inv:access="external" scope="local" type="abcb-glossentry">climate zones</xref> 4, 6 and 7 — 1.3; and</li><li id="_94f73a95-4aa7-4688-963b-282ca418429d">in <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_28a49bbd-8575-4295-9ab1-61601ae1cb9f" inv:access="external" scope="local" type="abcb-glossentry">climate zone</xref> 8 — 1.3.</li></ol></subclause><callout id="_6cae13cd-c496-4e77-846d-d8ee68daf999"><callout-type ncc-info-type="info"/><ul outputclass="numbered"><li>The insulation levels in <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4515_1.3.0.xml#_6ce12d7f-e6a3-4d06-9b6b-3a9267a7cc0c" id="_88a54a51-0f5d-40ea-b4d6-150a26af9a40" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Explanatory Table 13.7.3</xref> are typical examples of materials that can be used to insulate central heating water <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_826282c3-3ed6-4c00-bbff-332197871476" scope="local" type="abcb-glossentry">piping</xref> calculated in accordance with AS/NZS 4859.1.</li><li>The <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_91a57fc2-2873-467f-b38f-c50a0d8f15d5" scope="local" type="abcb-glossentry">R-Value</xref> is that of the insulation and not the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1490_25.4.0.xml#_bf26e61b-dbc1-4c09-b8be-ac8d936c0ac9" id="_ff8644b6-7a75-43a3-800c-5d2a34b2a7b7" scope="local" type="abcb-glossentry">Total R-Value</xref> of the pipe, air film and insulation. Where <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_411213b9-ae63-4387-9136-937c3bdf6d49" scope="local" type="abcb-glossentry">piping</xref> has a significant inherent <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_8ddbfd07-8334-4d02-a305-8fd46d178b52" scope="local" type="abcb-glossentry">R-Value</xref> it may be subtracted from the material <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_1ef0168c-8b0a-4653-89a9-2d53e106bba3" scope="local" type="abcb-glossentry">R-Value</xref> <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1432_4.0.0.xml#_af6fde9f-147d-4782-8b85-42044e80fd42" id="_3a5f6b09-6177-4edd-9805-a45b797cf889" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">required</xref>. However, the inherent <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_5e3e2c51-ac5b-48ec-b83b-294065299b23" scope="local" type="abcb-glossentry">R-Value</xref> of most piping is not sufficient to satisfy the requirements of 13.7.3.</li><li><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_55353475-dd42-42e4-97dc-9836a220b2d2" scope="local" type="abcb-glossentry">Piping</xref> within a timber member, such as that passing through a wall stud, is considered to have sufficient insulation for the purposes of 13.7.3.</li><li><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4515_1.3.0.xml#_6ce12d7f-e6a3-4d06-9b6b-3a9267a7cc0c" id="_6c9adf35-54d0-4e62-8a2e-bfb967398eac" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Explanatory Table 13.7.3</xref> provides examples for the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1420_0.4.0.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_ce6173c8-2ea0-4724-bc62-57f094a61db3" scope="local" type="abcb-glossentry">R-Value</xref> of the insulation used for smaller diameter <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1399_0.5.0.xml#_83695a00-3a6b-4a83-b26a-9faa46d4e1dc" id="_773a0c55-6a1d-47f6-b719-f0ce72b44c88" scope="local" type="abcb-glossentry">piping</xref>.</li></ul><table-reference conref="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4515_1.3.0.xml" graph="None" id="_6ce12d7f-e6a3-4d06-9b6b-3a9267a7cc0c"><num>13.7.3 (explanatory)</num><title id="_ceb73e5c-a269-461b-86fb-ccaedfe4b2e8">R-Value of insulation used for smaller diameter piping</title><table id="_ff47d8c8-35db-498b-b183-4f2ac52b6191" keycol="1"><tgroup cols="2"><colspec colname="001" colnum="1" colwidth="216.00*"/><colspec colname="002" colnum="2" colwidth="216.00*"/><thead><row><entry>Insulation</entry><entry><xref format="dita" href="ERROR_IN_RESOLVING_URI:r-value.xml#_e5acb40f-3d3d-4a3d-8987-f09f7eaadf77" id="_54ab86cb-0002-4707-875a-3553f73b02f7" scope="local" type="abcb-glossentry">R-Value</xref></entry></row></thead><tbody><row><entry>9 mm of closed cell polymer</entry><entry>0.4</entry></row><row><entry>13 mm of closed cell polymer</entry><entry>0.6</entry></row><row><entry>19 mm of closed cell polymer</entry><entry>0.9</entry></row><row><entry>25 mm of closed cell polymer</entry><entry>1.3</entry></row><row><entry>25 mm of glasswool</entry><entry>1.3</entry></row></tbody></tgroup></table></table-reference></callout></clause>