<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_e7f4c59d-fe9b-43a9-b1cd-3982e9e2d929" outputclass="ncc-clause" variation="SA"><sptc>I3D13</sptc><title id="_6b9a6d70-9653-4f39-9f5d-64002ce652c5">Exit signs</title><subclause id="_54f265cd-ca4b-4fd2-916e-e8579e8d2281" outputclass="subclause"><title id="_724264e2-ea8b-4ab7-9f00-6683117b5c3f">SubClause</title><num>1</num><p>An exit sign must be clearly visible to persons approaching the exit, and must be installed on, above or adjacent to each required exit in a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1271_2.5.0.xml#_f68a626d-6a81-4785-95fa-c032c987c28e" id="_03f2469b-6184-494b-9771-e1f1b8040c3d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">farm building</xref>.</p></subclause></clause>