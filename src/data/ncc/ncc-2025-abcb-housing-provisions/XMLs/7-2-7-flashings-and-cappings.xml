/num><title xmlns:inv="urn:xpressauthor:xpressdocument" id="_43cc27e7-53ec-4623-8b50-1338ca693b78" inv:access="external">Collar flashings—Typical roof penetration flashing details</title><image xmlns:inv="urn:xpressauthor:xpressdocument" alt="Collar flashings—Typical roof penetration flashing details" height="918" heightdpi="200" href="ERROR_IN_RESOLVING_URI:7-2-7e-collar-flashings-typical-roof-penetration-flashing-details.eps" inv:access="external" width="1200" widthdpi="200"/></image-reference><image-reference conref="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/651_0.6.0.xml" id="_dadc7336-4ab3-4fd1-aed9-452d52e62bd6"><num xmlns:inv="urn:xpressauthor:xpressdocument" inv:access="external">7.2.7f</num><title xmlns:inv="urn:xpressauthor:xpressdocument" id="_6f388674-f0fb-4b4e-a8f1-a1c820cd467d" inv:access="external">Large penetrations using apron—typical roof penetration flashing details</title><image xmlns:inv="urn:xpressauthor:xpressdocument" alt="Large penetrations using apron—typical roof penetration flashing details" height="510" heightdpi="200" href="ERROR_IN_RESOLVING_URI:7-2-7f-large-penetrations-using-apron-typical-roof-flashing-penetration-details.eps" inv:access="external" width="1200" widthdpi="200"/></image-reference></clause>