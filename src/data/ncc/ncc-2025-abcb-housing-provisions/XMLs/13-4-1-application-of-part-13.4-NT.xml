<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_409cfe24-f064-4d58-908d-711b05ec0377" outputclass="ncc-clause" variation="NT"><sptc>13.4.1</sptc><title id="_5bb48ed8-725e-475c-abd3-eeb00db039e5">Application of Part 13.4</title><archive-num>New for 2022</archive-num><subclause id="_292b7a86-8f6d-4b99-a215-4df833b434d9" outputclass="subclause"><title id="_2c1b9219-79fd-45ea-b793-c805498c4e16">SubClause</title><num>1</num><p>This Part applies to— </p><ol outputclass="alpha"><li id="_4a7e7af4-3823-46f0-9a51-2d6179cb929a">a Class 1 building; and </li><li id="_97a555ef-313f-4590-8e3f-de76a369454b">a Class 10a building with a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1225_1.8.0.xml#_6f4c27ea-b6b3-468c-9ff4-72d533d9d0a2" id="_48161451-5695-48a6-b1de-7fb47e50976a" referencetype="Text" scope="local" synctargettext="false" type="glossterm">conditioned space</xref>.</li></ol></subclause><callout id="_10a856e2-3855-4035-83eb-bcbd1cedb513"><callout-type ncc-info-type="application"/><p>This Part does not apply to:</p><ol outputclass="alpha"><li id="_07ccd920-d508-4e62-8e28-60cbf75f398b">A building where the only means of air-conditioning is by using an evaporative cooler.</li><li id="_fa7c83dc-c1a3-4e14-b743-5def8935123e">A permanent building ventilation opening that is necessary for the safe operation of a gas appliance.</li><li id="_afd2470b-c148-4f04-aa55-3f0bd432b40e">A Class 10a building used for the accommodation of vehicles.</li></ol></callout></clause>