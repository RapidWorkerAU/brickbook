<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_1ff5c2fd-1c2f-421d-aab0-a877f426a827" outputclass="ncc-clause" variation="NT"><sptc>13.4.2</sptc><title id="_5ea2a320-e143-4f5c-9917-d79c1108077c">Chimneys and flues</title><archive-num>New for 2022</archive-num><subclause id="_efdfd1bb-bd86-4a8c-a0ad-ee41af42851a" outputclass="subclause"><title id="_447a4230-61c4-4b77-89eb-f8cc93762f88"/><num>1</num><p>The chimney or flue of an open solid-fuel burning appliance must be provided with a damper or flap that can be closed to seal the chimney or flue.</p></subclause></clause>