<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_1b08eda5-6e73-457c-876e-2836f078651d" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>E1D5</sptc><title id="_6d25c934-4cff-4f70-8837-fac579458bf0">Where sprinklers are required: all classifications</title><archive-num>2019: Table E1.5</archive-num><subclause id="_95ce0eab-cf67-4429-a25b-cca6cb218d4f" outputclass="subclause"><title id="_8a21c61c-1036-428a-9b9b-6202eca3b59f">SubClause</title><num>1</num><p>Sprinklers are <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1432_4.0.0.xml#_af6fde9f-147d-4782-8b85-42044e80fd42" id="_c24fe9b5-872f-4a5c-900b-f515e768bc07" scope="local" type="abcb-glossentry">required</xref> throughout the whole building if any part of the building has an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1252_2.0.0.xml#_cd986c21-bc64-43a9-954d-86e35d335b74" id="_ade6dc91-7ab1-4d4f-ae18-18d1348bcd61" scope="local" type="abcb-glossentry">effective height</xref> of more than 25 m.</p></subclause><callout id="_b4c58592-5873-4ee5-8563-05be89fe8eb7"><callout-type ncc-info-type="exemption"/><p>E1D5 does not apply to—</p><ol outputclass="numbered"><li id="_4bc113f1-8f0c-48d1-bd1b-3e699034f17e">a class 7a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1384_4.0.0.xml#_98f99be0-5c03-48a8-8087-27bc99acc90d" id="_e64e78e5-2590-4dcf-8a3d-10bfe78a9236" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">open-deck carpark</xref> that is a separate building; or</li><li id="_d5a4daa4-f3f6-4c16-bc1a-efa69df9e9e6">a Class 8 <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1255_0.4.0.xml#_7a37df1f-0b8b-4b03-94ca-69ea423a363f" id="_4e0a3a51-08ce-4951-a591-2398c6bce247" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">electricity network substation</xref> with a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1314_2.10.0.xml#_7da927fe-453e-424f-b6ec-280f4e464397" id="_6f7bfc3f-77a4-41fb-8cfc-cad7faacc3fc" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">floor area</xref> not more than 200 m<sup id="_8867fd93-63b9-4c8b-a7a6-d10061572b93">2</sup> located within a multi-classified building.</li></ol></callout></clause>