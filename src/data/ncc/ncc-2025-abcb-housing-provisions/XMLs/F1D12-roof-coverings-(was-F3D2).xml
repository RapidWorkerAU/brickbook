<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_55bd0981-45c3-4601-a35c-e14081f866aa" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>F1D12</sptc><title id="_0d27f459-c572-48f8-b46d-ff8af4935106">Roof coverings</title><archive-num>2019: F1.5</archive-num><subclause id="_d91349ae-06d0-4f01-8548-cd691b8cebd2" outputclass="subclause"><title id="_e5b7ca8c-82b0-446d-aece-bc576d3e0621">SubClause</title><num>1</num><p>A roof must be covered with—</p><ol outputclass="alpha"><li id="_f7ffda44-d54e-4fe0-a04e-b2ff8bf70ea9">roof tiles complying with AS 2049, fixed in accordance with AS 2050; or</li><li id="_0b035cc6-98a9-44fc-81c5-1723ada8a095">metal sheet roofing complying with AS 1562.1; or</li><li id="_4815386a-81c0-4f6d-b3a5-6ab272d4cf2d">plastic sheet roofing designed and installed in accordance with AS 1562.3; or</li><li id="_3c2b773c-9a6b-4090-8d58-c91205f2bebd">terracotta, fibre-cement and timber slates and shingles designed and installed in accordance with AS 4597, except in cyclonic areas; or</li><li id="_6aa0828f-6cdf-4e50-9064-bd45a771f17c">an external waterproofing <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4651_0.4.0.xml#_6e2c1aaa-5993-4850-908f-ac4007e94535" id="_810cd4bc-f991-45da-916d-9cbe343e3caf" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">membrane</xref> complying with <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4966_0.27.0.xml#_458b78ec-911a-4b5f-8160-057e0892653c" id="_fcba4897-2ef1-47ea-a06d-3e46ea4f0543" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">F1D7</xref>.</li></ol></subclause></clause>