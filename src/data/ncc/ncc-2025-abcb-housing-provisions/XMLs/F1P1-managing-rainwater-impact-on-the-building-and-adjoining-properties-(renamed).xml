<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_6b4ccabc-18a9-45ef-a34e-d56bbecce29b" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>F1P1</sptc><title id="_3185b876-519f-4ecd-81f9-02c7e86b7c3c">Managing rainwater impact on the building and adjoining properties</title><archive-num>2019: FP1.1</archive-num><subclause id="_2d2ccbe6-a836-421b-85ea-b72c2dc96124" outputclass="subclause"><title id="_9e6dcdfd-5f4c-4cf0-80e0-d61832a6940e">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9511_0.7.0.xml#_022a6a17-e1b4-412a-b84c-3ea9c214b02c" id="_bdcfa204-9f7d-437d-9e3e-1857ecebd1b2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Water</xref>, including <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9511_0.7.0.xml#_022a6a17-e1b4-412a-b84c-3ea9c214b02c" id="_8791ab96-3cec-4829-9180-df87d3b8cafd" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">water</xref> on the surface of the <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9420_0.3.0.xml#_12287a7f-71ac-46bd-a629-7648a4b5a252" id="_0536ca3e-499c-4f11-9df4-0e9249aa70c1" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">allotment</xref> that is <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9432_0.9.0.xml#_e14fe7c6-ad26-4297-b38c-0cc6e9f6f3d0" id="_e292968c-409c-4316-be5c-fe4fef8e592e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">collected</xref> by a building or associated <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1464_25.0.0.xml#_99d8dfad-fc38-462e-a8a6-e0d4a548b2ff" id="_bccda35a-9355-4382-a8dd-6266dae1b041" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">sitework</xref>, must be <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9480_0.6.0.xml#_19dd48b1-70e1-4c21-8427-729299276926" id="_aed8cf7f-e749-4305-90b1-e9fd691f2d36" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">redirected</xref> to a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9440_0.8.0.xml#_8310df67-b7b9-4f62-b022-0655a2ae4428" id="_33bec0a2-8aef-4a7c-ad94-76e6218c9ee1" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drainage system</xref> to prevent—</p><ol outputclass="alpha"><li id="_542246bf-fcc4-42f2-92a1-d702a5faef9e">unhealthy or unsafe conditions, or loss of amenity for occupants within the building; and</li><li id="_ad37c99e-77ab-48ae-b08e-a8196a3aa708">undue damage to internal surfaces and other building elements; and</li><li id="_9bd22e33-bb6b-4c60-be03-4fc6e05f414a">undue damage or nuisance to other buildings and any <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1387_0.4.0.xml#_ffbca87e-eb18-4463-a6fb-e59b79881fa3" id="_4b6ede86-8860-48a6-afa8-8898a3c8b84c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">other property</xref>.</li></ol></subclause><subclause id="_e1e4926f-37ba-4c0f-be2a-622251a132a9" outputclass="subclause"><title id="_6a88dcc6-dc71-41b4-a526-12ce9c9f868d">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9511_0.7.0.xml#_022a6a17-e1b4-412a-b84c-3ea9c214b02c" id="_a5a12bc5-081b-476a-9c7f-5d894fbde590" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Water</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1432_4.0.0.xml#_af6fde9f-147d-4782-8b85-42044e80fd42" id="_da552027-d369-4992-96c1-3cd8c1791f56" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">required</xref> to be drained and resulting from a rain event with an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4602_0.3.0.xml#_74a0923e-1a7a-4396-a7ae-50c537bdfe8d" id="_569d4046-2f2f-478a-9836-ce978f4a55da" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">annual exceedance probability</xref>, with a five-minute duration period, of 5% satisfies (1) if it is—</p><ol outputclass="alpha"><li id="_7ade1053-816f-466a-9397-34c064606caf">disposed of in a way that avoids the likelihood of damage to the building; and</li><li id="_a92496f2-346e-47f3-9599-76791281ed65">conveyed through a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9440_0.8.0.xml#_8310df67-b7b9-4f62-b022-0655a2ae4428" id="_bbec6f14-042c-437f-a10d-28fae6709597" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drainage system</xref> to an appropriate <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1390_4.1.0.xml#_828371c4-72b7-4dcc-bdb6-8bcf8232fca3" id="_5ba1c23b-efe9-4154-ba15-1a80c092b1c0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">outfall</xref>.</li></ol></subclause><subclause id="_d1113b0f-9e63-4818-a405-1ce94f53eb0a" outputclass="subclause"><title id="_d0cc9c1d-861a-43e5-b2bd-44b60942e509">SubClause</title><num>3</num><p><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9511_0.7.0.xml#_022a6a17-e1b4-412a-b84c-3ea9c214b02c" id="_14619dc0-de67-40dd-a2cc-722b99bb4c90" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Water</xref> resulting from a rain event with an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4602_0.3.0.xml#_74a0923e-1a7a-4396-a7ae-50c537bdfe8d" id="_5dc65a2c-c223-4d11-bb08-9cc8fb84e2e8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">annual exceedance probability</xref>, with a five-minute duration period, of 1% collected or concentrated by building elements satisfies (1) if it is disposed of in a way that prevents—</p><ol outputclass="alpha"><li id="_ce3900ba-bc4f-40d5-a4a0-f6f8a6fb03d9">unhealthy or unsafe conditions, or loss of amenity for occupants within the building; and</li><li id="_2b5a18e1-0639-46ac-8c37-353a8966c495">undue damage to internal surfaces and other building elements.</li></ol></subclause><subclause id="_7b21005c-5bef-4170-8741-65e081dfb613" outputclass="subclause"><title id="_c11de48e-ca2d-4d92-a8b8-7a3884c60c00">SubClause</title><num>4</num><p><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/9511_0.7.0.xml#_022a6a17-e1b4-412a-b84c-3ea9c214b02c" id="_90cde190-0509-4d46-8cec-7cfe4d880f0a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Water</xref> resulting from a rain event in (2) and (3), subject to wind action with an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4602_0.3.0.xml#_74a0923e-1a7a-4396-a7ae-50c537bdfe8d" id="_3397d484-0f67-486a-8ca1-ad9918926230" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">annual exceedance probability</xref> of 4%, collected or concentrated by a building satisfies (1) if it is disposed of in a way that prevents—</p><ol outputclass="alpha"><li id="_7643c921-dcdf-40d3-a668-d1af97934cc4">unhealthy or unsafe conditions, or loss of amenity for occupants within the building; and</li><li id="_ff7314b5-8a51-4dce-9324-cb45712c11a5">undue damage to internal surfaces and other building elements.</li></ol></subclause><callout id="_6a465e9a-9043-43c8-ae85-c18da2362c78"><callout-type ncc-info-type="notes"/><p>For the purposes of F1P1(3)—</p><ol outputclass="alpha"><li id="_734b9bf7-e316-4359-aac2-6e532b24c9bf">building elements include external walls, openings around windows and external doors, roofs, balconies, podiums, attached awnings, similar horizontal surface parts of a building and stormwater overflow systems; and</li><li id="_8cabd2f3-e4c3-47ca-a588-d480906a4214">an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/4602_0.3.0.xml#_74a0923e-1a7a-4396-a7ae-50c537bdfe8d" id="_b88bb45d-df97-402d-849b-9bd5cc9279f4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">annual exceedance probability</xref> of 5% can be applied to awnings and roofs with or without eaves gutters and where overflow, if applicable, is external to the building.</li></ol></callout><callout id="_02b11724-c868-4e51-a3b6-ca6690754eef"><callout-type ncc-info-type="exemption"/><p>F1P1(1), F1P1(3) and F1P1(4) do not apply to—</p><ol outputclass="alpha"><li id="_22ad33c8-b734-4447-894c-93d3ee40592e"><xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1224_0.8.0.xml#_7bd3fe3a-8528-4438-a6cb-6f4b43993774" id="_e1f47f77-dfe3-4cb3-bf16-a75323e32651" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">condensation</xref>; or</li><li id="_fa72d07f-66fa-4bc6-a51e-aac6983663b0">a <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1414_4.2.0.xml#_230a3a0f-1539-4b9d-9a2d-8edf732e59dd" id="_d0812b71-7f8e-4b34-a59f-2fe71bb89cc7" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">private garage</xref>, tool shed, <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1445_0.13.0.xml#_b30a308f-eb9f-4549-a6c1-19d5f32a5272" id="_85340dfe-9641-4af9-bc9f-7c038a26be11" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">sanitary compartment</xref> or the like separate from, or forming part of, a building used for other purposes; or</li><li id="_f9e87786-bbfc-4bd7-915a-d7f0909f24fc">an <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1386_0.4.0.xml#_0403e22a-286f-4b36-b369-af068221632b" id="_424b82e2-b63d-49d7-b38e-2d4f99b5e19a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">open spectator stand</xref> or <xref format="dita" href="/tmp/QppServer/Publishing/601d5817-38d4-46f4-a9ae-3e54027c73d5/1384_4.0.0.xml#_98f99be0-5c03-48a8-8087-27bc99acc90d" id="_e766010b-5761-44a1-93a4-f0d3d097bbaa" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">open-deck carpark</xref>.</li></ol></callout></clause>