<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_9474fb9b-ecca-4af2-bd21-77d1829401a9" outputclass="ncc-clause"><sptc>B2P4</sptc><title id="_c07b55f1-9baa-46f7-88fe-99cf867e3e05">Access</title><archive-num>2019: BP2.3</archive-num><subclause id="_bbc4e885-44ca-46b2-ab39-a3471543e0e7" outputclass="subclause"><title id="_7fe1b177-bd12-4222-848e-c5bbe4ebf20d">SubClause</title><num>1</num><p>Access must be provided to components of a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_35f06226-c600-4e32-9346-0d909f58eb26" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref> service that require maintenance or replacement, including mechanical devices and controls.</p></subclause><callout id="_0ad48fba-ea11-4a23-a9f2-84c9b63f8199"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door, or similar obstruction.</p></callout></clause>