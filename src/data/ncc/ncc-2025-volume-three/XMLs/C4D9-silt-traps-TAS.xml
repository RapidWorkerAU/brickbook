<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_46f3fc18-1a62-43a0-9ba8-b6367a32a17e" outputclass="ncc-clause" variation="TAS"><sptc>C4D9</sptc><title id="_f1bc66e2-5bf8-40cd-8198-8c173609ebb0">Silt traps</title><archive-num>2019: H202.4b</archive-num><subclause id="_2b323070-1393-4558-9fbb-ba070a6478cc" outputclass="subclause"><title id="_08277589-4232-4e0c-aed6-e64385201f76">SubClause</title><num>1</num><p>The silt trap must be connected and authorised by the Permit Authority.</p></subclause><subclause id="_d32e3e03-e4e1-42af-ac1f-721c9c9b9254" outputclass="subclause"><title id="_4e58027d-22e8-4095-97d9-c1318eaeadd1">SubClause</title><num>2</num><p>The silt trap bucket must—</p><ol outputclass="alpha"><li id="_6b3192dc-de47-40fd-bf63-7d3bbf11cd23">be constructed of mild steel plate, minimum 3 mm thick with 5 rows of 10 mm diameter holes at 25 mm centres; and</li><li id="_11491dd7-709b-407e-9a82-4f17e0dfaaff">be hot dipped galvanised after fabrication.</li></ol></subclause><callout id="_e95010f7-76cf-4a10-9786-20ebea2bfe4d"><callout-type ncc-info-type="info"/><p>See <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/7746_0.4.0.xml#_b1260429-ac6d-4810-a0c7-69bc2bda3415" id="_7af49a13-4df5-41ae-853c-aa138b9323fb" referencetype="Text" scope="local" synctargettext="false" type="image-reference">TAS Figure C4D9</xref> for a typical silt trap.</p><image-reference conref="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/7746_0.4.0.xml" id="_b1260429-ac6d-4810-a0c7-69bc2bda3415" variation="TAS"><num/><title id="_c5f93222-3b9a-45d1-869c-d8cd437a6e24"/></image-reference></callout></clause>