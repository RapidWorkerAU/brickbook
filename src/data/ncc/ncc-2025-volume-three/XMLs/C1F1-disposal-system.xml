<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_7e056d23-689d-476c-84f7-a572a0a6623f" outputclass="ncc-clause"><sptc>C1F1</sptc><title id="_62252a6e-9d1f-4333-9f72-1ac2a09d33ad">Disposal system</title><archive-num>2019: CF1</archive-num><subclause id="_c63eb491-eefd-481d-bda1-a76a2f172e0b" outputclass="subclause"><title id="_a5045347-e28d-4282-a072-bba54c1c9a84">SubClause</title><num>1</num><p>Sanitary fixtures and sanitary appliances must be provided with an adequate disposal system that does not impact adversely on the occupants of the premises, property, the environment or the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_59ec717c-974f-474d-ba1e-9c3e3f9b9470" scope="local" type="abcb-glossentry">Network Utility Operator’s</xref> infrastructure.</p></subclause></clause>