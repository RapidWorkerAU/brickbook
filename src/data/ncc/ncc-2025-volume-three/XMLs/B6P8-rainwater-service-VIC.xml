<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_4e53c3e3-40a9-49ff-b16c-19c979c2b3b9" outputclass="ncc-clause" variation="VIC"><sptc>B6P8</sptc><title id="_6871feba-49ad-41d0-bdd3-8656983f39b2">Rainwater service</title><archive-num>New for 2022</archive-num><subclause id="_1c6ff675-73d7-4395-9722-9e91dc715e52" outputclass="subclause"><title id="_f0a5378e-9c37-4c7b-af85-56f2716395ae">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1422_4.4.0.xml#_bd764954-3054-4109-81f2-164feefc5058" id="_aae8f14f-d136-4f0e-bd93-5aa5d046e721" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater service</xref> must—</p><ol outputclass="alpha"><li id="_25e39c9b-6f63-4a1c-be40-3d9648d94968">avoid the likelihood of contamination of water within the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1422_4.4.0.xml#_bd764954-3054-4109-81f2-164feefc5058" id="_6bb83b88-3372-4e38-8ec4-e2ed7e9622a9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater service</xref>, the cold water service, or the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_8c504ef8-caae-4ea5-b882-558e58fff3b2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Network Utility Operator's</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_c24bc280-638d-4a2f-afdc-795c26bb5381" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drinking water</xref> supply (if connected); and</li><li id="_432ca229-fadf-4535-b034-a9200fc1c8e2">not pose a hazard to public health; and</li><li id="_e320d5b8-73cf-4d74-ab28-95cdf5e9c855">not have an unprotected <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1233_1.0.0.xml#_b3f409ec-8f72-48d9-8a64-0dc9d5fb5d67" id="_9fd0d223-f8d3-4348-96d7-11ceccf91e53" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cross-connection</xref> with any <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_4ef3ef50-53ed-463c-891b-6e5a6531bdc4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Network Utility Operator's</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_4edc18ff-fca7-451e-9052-82a15470e521" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drinking water</xref> service; and</li><li id="_b69622fa-1e7a-4ca2-876a-8f6c96174190">ensure continual supply of water for sanitary flushing.</li></ol></subclause><callout id="_e499a5e9-d868-4b15-ba08-a758e81b9c23"><callout-type ncc-info-type="application"/><p>B6P8(d) applies if a reticulated water supply from a network utility operator is connected, or proposed to be connected, to a building where a rainwater tank is installed for the purpose of sanitary flushing.</p></callout></clause>