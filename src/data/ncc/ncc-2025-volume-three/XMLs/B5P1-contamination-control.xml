<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_c3b8a47f-fb69-4db2-8d70-1722ad82032d" outputclass="ncc-clause"><sptc>B5P1</sptc><title id="_451b082a-238c-4a9c-8d3e-6ec0d0ec8190">Contamination control</title><archive-num>2019: BP5.1</archive-num><subclause id="_c2ccec2d-a2b9-4202-8fc5-87bdb1af38cb" outputclass="subclause"><title id="_9a38ec6f-6607-437b-a750-64c02c6a188a">SubClause</title><num>1</num><p>Water services must be designed, constructed and installed to avoid contamination.</p></subclause><callout id="_3e0855af-2b74-4911-9d09-d8f81d7f372e"><callout-type ncc-info-type="application"/><p>B5P1 applies to cold water, <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_31bdf1f0-6be1-469a-a482-c766b70a467a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref>, <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1378_4.3.0.xml#_cfc4fec0-3cb7-41d6-b176-4a92d4cdb221" id="_673c99cd-117b-41e3-81eb-239612a64e8b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">non-drinking water</xref> and fire-fighting water services.</p></callout></clause>