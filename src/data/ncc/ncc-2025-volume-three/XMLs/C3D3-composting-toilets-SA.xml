<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_0b07216d-f536-4fb2-8d6a-1966e5289b99" outputclass="ncc-clause" variation="SA"><sptc>C3D3</sptc><title id="_2e2e4caa-1b7b-468c-b5b4-eeec3db3452b">Composting toilets</title><archive-num>New for 2022</archive-num><subclause id="_df749bee-88b8-4dc3-88d1-e5f8c8a16a2b" outputclass="subclause"><title id="_07821cc8-253f-45c5-9fab-397ea8a97b1b">SubClause</title><num>1</num><p>A waterless composting toilet must be in accordance with the South Australia On-Site Wastewater Systems Code. </p></subclause></clause>