<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_28a80c20-b6a5-4400-9263-b64d8b1564d6" outputclass="ncc-clause" variation="WA"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>H9D3</sptc><title id="_a0b2c83f-3af8-45dc-8df1-785c0fea6d05">Swimming pool covers and blankets</title><archive-num>2019: WA 2.3.2</archive-num><subclause id="_ef0fc248-042f-46f4-ac51-bbc8a1780452" outputclass="subclause"><title id="_0e48817f-d292-4599-b8e7-cb5e22158f70">SubClause</title><num>1</num><p>An outdoor private <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1487_0.7.0.xml#_4cbd9e00-0622-4dfd-9de4-913c80257732" id="_22c78e11-f2be-4619-a697-922e30bbb1a0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">swimming pool</xref> or spa associated with a Class 1 building must be supplied with a cover, blanket or the like that—</p><ol outputclass="alpha"><li id="_d5b6ea4c-193d-4236-8547-e332e9fe4ba3">is designed to reduce water evaporation; and</li><li id="_34dccd9a-2300-43a1-b586-bdc555f01f56">is compliant with Australian Standard AS 5348:2022 Pool Covers.</li></ol></subclause></clause>