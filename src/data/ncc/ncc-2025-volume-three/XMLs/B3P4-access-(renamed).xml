<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_cb5cdeff-befe-47ff-84ab-c83455700daf" outputclass="ncc-clause"><sptc>B3P4</sptc><title id="_e2107b78-d7fb-4519-abda-0503d33c0bef">Access</title><archive-num>2019: BP3.3</archive-num><subclause id="_adf68b08-e59a-4256-807c-7f15e799130e" outputclass="subclause"><title id="_49a9dba3-94b2-419e-a182-1df2cac2122a">SubClause</title><num>1</num><p>Access must be provided to components of a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1378_4.3.0.xml#_cfc4fec0-3cb7-41d6-b176-4a92d4cdb221" id="_78d966fc-3b75-4821-8226-567fb56f68ee" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">non-drinking water</xref> service that require maintenance or replacement, including mechanical devices and controls.</p></subclause><callout id="_9825f2d8-4b40-4098-bec0-f7637b702123"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door, or similar obstruction.</p></callout></clause>