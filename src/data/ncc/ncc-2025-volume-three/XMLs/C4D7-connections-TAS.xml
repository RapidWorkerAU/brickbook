<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_36b4ccd8-d44e-435d-82d1-4d1e41844299" outputclass="ncc-clause" variation="TAS"><sptc>C4D7</sptc><title id="_9ae4caaf-4d3c-49af-bf63-9bfc072156b3">Connections</title><archive-num>2019: H202.2</archive-num><subclause id="_fc561039-26be-4953-a9f3-1030e337422f" outputclass="subclause"><title id="_98c415b6-3413-4854-b3de-0fe74f78bc0e">SubClause</title><num>1</num><p>The <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1401_0.7.0.xml#_a318c0f3-5635-4ac0-b103-59d798c9f23d" id="_f136e25a-42c1-4d5f-aac9-3d1abe86b8ed" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">plumbing</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1249_0.8.0.xml#_25307451-c7e1-4167-b4de-e5a1af26694c" id="_7b7c99b2-53a5-436a-a949-15f95c48bf78" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drainage</xref> installation upstream of a low-risk trade waste appliance must comply with AS/NZS 3500.2</p></subclause><subclause id="_de4b2d2c-f3db-4129-9c6f-c0630481a280" outputclass="subclause"><title id="_6130ccfa-105b-49f1-a950-29fc7145dd16">SubClause</title><num>2</num><p>The sanitary <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1401_0.7.0.xml#_a318c0f3-5635-4ac0-b103-59d798c9f23d" id="_756a73d5-6f87-4b13-929a-ffedb21ae5d9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">plumbing</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1249_0.8.0.xml#_25307451-c7e1-4167-b4de-e5a1af26694c" id="_5ba65cb8-8f25-4965-9f05-c688cf03981d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drainage</xref> system must be compatible to the nature of the waste.</p></subclause><subclause id="_48a14e80-04ee-46f7-bcaa-b7783ce56b4e" outputclass="subclause"><title id="_1694aadf-7e38-485f-96d9-347d6c16159e">SubClause</title><num>3</num><p>A trap must be fitted to every fixture or appliance outlet and must be—</p><ol outputclass="alpha"><li id="_1c56f3e2-302e-43fa-8cd9-db555ac7a622">DN 50 minimum for a portable appliance with hydraulic loading up to 5 fixture units; or</li><li id="_d1a4d601-3044-4564-83f0-d76de4ce6c3b">DN 80 minimum for a portable appliance with hydraulic loading greater than 5 fixture units; or</li><li id="_a54eb264-6405-4e14-8ff0-9d51ae536a7d">DN 100 minimum for all other appliances.</li></ol></subclause><callout id="_2bd3f25c-b9f3-4efb-beea-2c51be80c92e"><callout-type ncc-info-type="exemption"/><p>Installations outside C4D7(1) may be permitted by the Permit Authority.</p></callout></clause>