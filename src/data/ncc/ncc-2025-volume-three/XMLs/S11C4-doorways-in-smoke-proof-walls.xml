<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_560dd71e-39cf-410a-aeb9-0696deab129f" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>S11C4</sptc><title id="_c8d40d45-5253-456e-bb65-cff0f72bec57">Doorways in smoke-proof walls</title><archive-num/><subclause id="_dde5ec54-6cd6-4d2c-8923-0c950fc9305f" outputclass="subclause"><title id="_3ae0628a-898c-4e89-843f-2799af183337">SubClause</title><num>1</num><p>A door <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1432_4.0.0.xml#_af6fde9f-147d-4782-8b85-42044e80fd42" id="_9948a21c-2f5d-46be-ae8d-71a96cf7f6e2" scope="local" type="abcb-glossentry">required</xref> by <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1266_1.21.0.xml#_426919a1-18e7-433d-a8df-bacb787134cf" id="_bccb951a-9803-433c-9f4b-7b5d76b0316f" scope="local" type="clause">C3D6</xref> or this Specification to be smoke-proof or have an FRL must provide a smoke reservoir by not extending within 400 mm of the underside of—</p><ol outputclass="alpha"><li id="_7f4b6046-9e9f-4736-9e2d-b3ae5d18dd63">a roof covering; or</li><li id="_f5ca25cc-34a8-46df-955e-ee4224cb88bd">the floor above; or</li><li id="_61cdd2fd-5eb5-4fe7-adb8-e1218528fca9">an imperforate false ceiling that will prevent the free passage of smoke.</li></ol></subclause></clause>