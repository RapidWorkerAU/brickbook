<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_ba6918bb-ac38-4203-84cf-9894454288bf" outputclass="ncc-clause" variation="NT"><sptc>13.4.3</sptc><title id="_de7ff2bd-4d69-47ae-965c-4c92edb2784d">Roof lights</title><archive-num>New for 2022</archive-num><subclause id="_bf1dcfb6-609c-4fef-b000-30af60e92a06" outputclass="subclause"><title id="_9105cd6e-9677-4360-b905-e41cdfc4407a">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1441_5.5.0.xml#_923cc200-bcae-4fb3-b11c-bf5caaab1c5f" id="_5b045d97-68d3-48c0-ac4a-4e3aa09e97e8" referencetype="Text" scope="local" synctargettext="false" type="glossterm">roof light</xref> must be sealed, or capable of being sealed, when serving a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1225_1.8.0.xml#_6f4c27ea-b6b3-468c-9ff4-72d533d9d0a2" id="_23e470b3-dd6b-428b-a95a-cd1d5fee632f" referencetype="Text" scope="local" synctargettext="false" type="glossterm">conditioned space</xref>.</p></subclause><subclause id="_26f5e6fc-aa8b-4186-9d0f-643c3f3424b5" outputclass="subclause"><title id="_fe44f232-3028-49a3-a507-d10d5631766a">SubClause</title><num>2</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1441_5.5.0.xml#_923cc200-bcae-4fb3-b11c-bf5caaab1c5f" id="_c3e355f7-26f4-4ead-b19f-8fe9b0a8aa5b" referencetype="Text" scope="local" synctargettext="false" type="glossterm">roof light</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1432_4.0.0.xml#_a5b45a91-1ac3-44a8-8644-acfc09c225a9" id="_e0ffe3f0-7508-4c1a-80bf-ec4f69ed7a3a" referencetype="Text" scope="local" synctargettext="false" type="glossterm">required</xref> by (1) must be constructed with—</p><ol outputclass="alpha"><li id="_d6914441-73ac-4af0-a63d-a720dc076699">an imperforate ceiling diffuser or the like installed at the ceiling or internal lining level; or </li><li id="_76ae293f-bb9c-40de-8364-7e3523954653">a weatherproof seal if it is a roof window; or</li><li id="_3351f7a1-c7ad-4d1f-a366-035b2ebd53a0">a shutter system readily operated either manually, mechanically or electronically by the occupant.</li></ol></subclause></clause>