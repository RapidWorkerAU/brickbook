<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_e164b1bc-f152-4cd1-8ac1-4112a339a87b" outputclass="ncc-clause"><sptc>B6P4</sptc><title id="_19ba63d6-17fe-4f51-b94d-9612951fd64f">Access</title><archive-num>2019: BP6.2</archive-num><subclause id="_6af987fc-4ae2-405f-830a-c8ce8e3be3a5" outputclass="subclause"><title id="_05c31cdb-9003-41cb-ade5-cfdcb2ffdf91">SubClause</title><num>1</num><p>Access must be provided to components of a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1422_4.4.0.xml#_bd764954-3054-4109-81f2-164feefc5058" id="_898e0d43-e580-43e8-941e-b93ad468cfec" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater service</xref> that require maintenance or replacement, including mechanical devices and controls.</p></subclause><callout id="_f8e4c44e-4647-4061-b9c1-b786bb1594ac"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door or similar obstruction.</p></callout></clause>