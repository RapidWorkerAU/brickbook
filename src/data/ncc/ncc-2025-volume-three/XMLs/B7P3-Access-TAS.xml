<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_0bb5b7a2-d269-4b17-85b8-eeb6028451e4" outputclass="ncc-clause" variation="TAS"><sptc>B7P3</sptc><title id="_9addec15-9d31-4002-a16e-4c0f36108b09">Access</title><subclause id="_e4fbaf14-6e1c-4062-bda9-f23cbbcd130a" outputclass="subclause"><title id="_895c22c2-368c-4e25-bc67-0bbda7c404fb">SubClause</title><num/><p>Access must be provided to components of <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/4891_0.8.0.xml#_a8d909a0-d649-477d-a969-848c9187c05d" id="_4eae153f-9615-4434-821f-94a550f6d14c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater storage</xref> that require maintenance or replacement, including mechanical devices and controls.</p></subclause><callout id="_8e29fd45-d240-433f-b223-fda3748631e1"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door, or similar obstruction.</p></callout></clause>