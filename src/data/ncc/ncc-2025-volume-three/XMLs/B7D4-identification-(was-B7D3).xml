<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_2231a64a-e710-40fb-9c3b-6491b342c8d5" outputclass="ncc-clause"><sptc>B7D4</sptc><title id="_dec42a97-b79a-49da-a859-701abdc07a7b">Identification</title><archive-num>2019: B6.5</archive-num><subclause id="_ff70f48a-521f-4e22-99f4-be470736f1c7" outputclass="subclause"><title id="_c7b3a23e-d23d-4ea9-a390-03ce302459ab">SubClause</title><num>1</num><p>The <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/4891_0.8.0.xml#_a8d909a0-d649-477d-a969-848c9187c05d" id="_1b8f0cab-63cd-42fb-8e2b-0c356a0804a2" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater storage</xref> must be identified as rainwater in accordance with AS/NZS 3500.1.</p></subclause><callout id="_aef0b83d-833c-4a4e-96e7-6d6f42a74fcd"><callout-type ncc-info-type="exemption"/><p>Where <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/4891_0.8.0.xml#_a8d909a0-d649-477d-a969-848c9187c05d" id="_926605d6-c6c9-4134-b495-931586d32368" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater storage</xref> is intended to supply water for drinking and personal hygiene, identification of the storage and holding tanks is not required.</p></callout></clause>