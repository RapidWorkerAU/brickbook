<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_607d4bbf-c42e-4026-8abb-3abd86d2fa9d" outputclass="ncc-clause"><sptc>B2D6</sptc><title id="_b6060b82-f933-49ea-950b-45f2d17a02fa">Temperature control devices</title><subclause id="_8dab7647-588e-4d74-8f55-5bebfe830cf9" outputclass="subclause"><title id="_99c66f4f-d914-434b-8bea-29046fccd349">SubClause</title><num>1</num><p>A temperature control device used to deliver <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_7969a79c-77d5-446c-bd21-40f2b81f56ce" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref> in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10297_0.6.0.xml#_a6547e5f-e97b-4e5d-a7ca-e5e71226dd33" id="_e45c1a0c-cf52-42d5-8c3a-c726b06b6045" referencetype="Text" scope="local" synctargettext="false" type="subclause">WA B2D5(1)(a)</xref> must be a—</p><ol outputclass="alpha"><li id="_9d72e29a-5adf-466c-a154-006fa25867bb">thermostatic mixing valve; or</li><li id="_929c8860-3c07-4e41-a273-fc4e2bb167b1">thermostatically controlled tap.</li></ol></subclause><subclause id="_6817c0ea-e963-49ff-8ffc-eea87cc1ff65" outputclass="subclause"><title id="_2d8ff3eb-feb9-4136-96ea-711f6402abd9">SubClause</title><num>2</num><p>A temperature control device used to deliver <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_a3271f2d-50f4-46a2-bd82-b234de0998b0" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref> in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10297_0.6.0.xml#_a6547e5f-e97b-4e5d-a7ca-e5e71226dd33" id="_43fd083e-4fe9-4479-903f-877b47b6ff02" referencetype="Text" scope="local" synctargettext="false" type="subclause">WA B2D5(1)(b)</xref> must be—</p><ol outputclass="alpha"><li id="_ab4ac159-06b7-4f74-8220-7c4f0e307047">thermostatic mixing valve; or</li><li id="_c0706f9e-deb1-46ca-999c-4f4360a2d2be">thermostatically controlled tap; or</li><li id="_5ce8ef8c-92f5-45f1-af3b-bcc905b91a29">tempering valve; or</li><li id="_f42b2ecc-c291-46a0-8bb9-5a4eb7e40e44">temperature limited water heater.</li></ol></subclause><subclause id="_1ba500f0-2082-4a47-b2cc-72c9348bc02a" outputclass="subclause"><title id="_08c9f6af-c80c-4e52-babc-e2ea98c91bee">SubClause</title><num>3</num><p>The required maximum delivery temperature must be achieved in accordance with AS/NZS 3500.4.</p></subclause><callout id="_1bd576c3-685c-431f-a953-5f9f5ce149d8"><callout-type ncc-info-type="application"/><p>WA B2D6 applies to <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_0dc61f6a-48a8-4580-8b80-049f12890be4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref> installations to which <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10297_0.6.0.xml#_8135c2d3-be01-4940-9248-cf1e27dcd88b" id="_2ecbeb26-1b5f-474f-9df7-5cb277835b27" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">WA B2D5</xref> applies.</p></callout></clause>