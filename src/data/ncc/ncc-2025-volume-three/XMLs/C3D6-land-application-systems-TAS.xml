<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_cad1c7d0-287d-43d4-95a8-f371adb50a65" outputclass="ncc-clause" variation="TAS"><sptc>C3D6</sptc><title id="_18788ea3-c2c5-4d58-8c16-def8ea60f294">Land application systems</title><archive-num>2019: HP1.4</archive-num><subclause id="_038dda80-9e16-40b3-a501-b30e0129a720" outputclass="subclause"><title id="_87bd034b-b0e8-4f66-996a-bdb37a526708">SubClause</title><num>1</num><p>An <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1383_4.5.0.xml#_2396187d-8435-4f01-9dfd-613970a74823" id="_ba004842-fba0-47c9-a5d5-8048ae3a117e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">On-site wastewater management system</xref> and associated land application system must avoid the following:</p><ol outputclass="alpha"><li id="_0e5bdfd6-2b71-4035-bad8-2178396db747">Damage from root penetration, superimposed loads or ground movement.</li><li id="_49f7c0f0-4403-4dbe-88c9-aa671d3aed7d">Entry of water, foul air or gasses from the system into buildings.</li><li id="_d0953fa7-e295-4c77-bdbd-0115b19dd807">Entry of stormwater into the system.</li><li id="_35bdd8e7-95c2-42eb-a3e3-721647dce0df"><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1209_1.2.0.xml#_417d94d8-f254-4788-9a14-c4c5da89daa6" id="_873f3404-3155-4b92-8a8a-185a2be57003" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Blockage</xref> and unintended or <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1500_27.0.0.xml#_0ece1af9-d663-4f17-a7c9-bf59ebb1b1ef" id="_ae00b879-42a4-4565-8e9c-80d91f5fc89d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">uncontrolled discharge</xref>.</li></ol></subclause><subclause id="_66b1eacd-a239-4ad9-a406-59c9522403e8" outputclass="subclause"><title id="_156e9474-ae86-4b77-ad83-39ee53008cb2">SubClause</title><num>2</num><p>An <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1383_4.5.0.xml#_2396187d-8435-4f01-9dfd-613970a74823" id="_f8078366-f5ad-45d8-81e7-275b7a7661a9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">On-site wastewater management system</xref> and associated land application system must provide the following:</p><ol outputclass="alpha"><li id="_3aaf469e-f385-4ec0-93ed-abe9140cf9af">Protection against internal contamination.</li><li id="_866d435f-a17d-4b25-8f8c-95fc78a7682f">Access for maintenance and cleaning.</li><li id="_ba3aea9d-ffb1-4b08-8d94-bf75ac1f315a">Ventilation to avoid foul air and gasses accumulation in the system.</li></ol></subclause><subclause id="_421b963f-a1d1-47ba-941e-dd41f23a8918" outputclass="subclause"><title id="_62cf7f1c-9230-4954-9c6e-20cf862715e7">SubClause</title><num>3</num><p>A facility must continue to satisfy the requirements of C3D6(1) and C3D6(2).</p></subclause></clause>