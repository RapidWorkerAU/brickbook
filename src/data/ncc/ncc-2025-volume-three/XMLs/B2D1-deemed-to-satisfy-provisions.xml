<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_771799f0-d4a4-4147-8269-bac68d78c482" outputclass="ncc-clause"><sptc>B2D1</sptc><title id="_ebb654e8-40c0-461a-8aa6-a6cc36ad9c55">Deemed-to-Satisfy Provisions</title><archive-num>2019: B2.1</archive-num><subclause id="_2c97c961-bca2-4914-9a47-06e97e6c9f30" outputclass="subclause"><title id="_f8f6e7d7-c79a-4dc4-be43-52a4e8ac9588">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_57b6665c-1348-4618-8391-6bb21b60f716" scope="local" type="abcb-glossentry">Performance Requirement</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1611_1.5.0.xml#_b3f5dc54-a238-4ff0-916f-0b4cbdb1f106" id="_4492b205-eb78-4c4e-b6f0-d519366c0cb8" scope="local" type="clause">B2P1</xref> is satisfied if <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_da50663c-f9db-49ec-aa51-f526d76d8170" scope="local" type="abcb-glossentry">heated water</xref> is supplied by—</p><ol outputclass="alpha"><li id="_edba3742-3033-419d-a372-96ccfcbdc4b7">the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_3d43b3ca-58ec-4adf-a2a6-b34358e2d228" scope="local" type="abcb-glossentry">Network Utility Operator’s</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_b857901f-0c7a-4750-8623-7b5bbbd1d879" scope="local" type="abcb-glossentry">drinking water</xref> supply; or</li><li id="_c582dd59-830f-4c59-9603-17529ac5e965">an alternative <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91