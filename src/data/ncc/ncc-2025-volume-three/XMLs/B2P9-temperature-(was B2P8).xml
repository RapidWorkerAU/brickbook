<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_b349977a-6d05-4bcd-978c-28943ac3a9da" outputclass="ncc-clause"><sptc>B2P9</sptc><title id="_e64850e2-cec5-4b29-9eba-a83b4b564ada">Temperature</title><archive-num>2019: BP2.3</archive-num><subclause id="_b9d457a8-ac4b-4eab-8257-084ef5a048e7" outputclass="subclause"><title id="_7799a92a-b3e8-4ef2-8424-fe246df4f0ee">SubClause</title><num>1</num><p>Heated water from a heated water service must be provided at appropriate temperatures for the correct functioning of fixtures or appliances.</p></subclause></clause>