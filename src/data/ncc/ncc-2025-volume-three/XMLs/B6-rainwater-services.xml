<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-part" ?><part xmlns:qxa="true" xmlns:xt="urn:xpressauthor:trackchanges" Buddy_ElementBookmark="Xpress_Internal_2" id="_d01d1657-8515-4bce-b9eb-f551728963d9" outputclass="ncc-part"><num Buddy_ElementBookmark="Xpress_Internal_3">B6</num><title Buddy_ElementBookmark="Xpress_Internal_4" id="_2c328301-3a63-469a-a90d-a80900d32f26">Rainwater services</title><intro-part Buddy_ElementBookmark="Xpress_Internal_5" id="_0d36f379-0720-49db-8d79-38e9813b7978"><p Buddy_ElementBookmark="Xpress_Internal_6">This Part sets out the requirements for any part of a <xref Buddy_EmphasisBookmark="Emphasis_1_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1422_4.4.0.xml#_bd764954-3054-4109-81f2-164feefc5058" id="_3c749674-9c55-48bb-b63d-ba3af9249fd8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater service</xref> from the <xref Buddy_EmphasisBookmark="Emphasis_2_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1403_3.16.0.xml#_7df493b5-1832-40a0-b9d0-d2fb3fec5d98" id="_4d0d20e5-e89d-444f-bcc3-221e9a4ceeaf" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">point of connection</xref> of the <xref Buddy_EmphasisBookmark="Emphasis_3_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/4891_0.8.0.xml#_a8d909a0-d649-477d-a969-848c9187c05d" id="_6ba6c5c0-597d-46a3-a278-b2421de26ad6" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater storage</xref>, to the rainwater points of discharge.</p><p Buddy_ElementBookmark="Xpress_Internal_7">This Part applies to a <xref Buddy_EmphasisBookmark="Emphasis_4_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1422_4.4.0.xml#_bd764954-3054-4109-81f2-164feefc5058" id="_4bed0555-7652-4dcd-aef3-9b00d95eeb88" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater service</xref> supplied by stored rainwater collected from a roof, where a separate cold water service is provided for drinking and personal hygiene from a <xref Buddy_EmphasisBookmark="Emphasis_5_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_1397ec66-a4bf-4372-aed5-c268ae15db2b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Network Utility Operator's</xref> supply.</p><p Buddy_ElementBookmark="Xpress_Internal_8">This Part does not apply to rainwater used only for irrigation purposes. </p><p Buddy_ElementBookmark="Xpress_Internal_9">Where water provided by a <xref Buddy_EmphasisBookmark="Emphasis_6_xref" format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_91ff6237-22ae-408f-bceb-892de104a103" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Network Utility Operator</xref> is not available or not utilised as the primary water source for drinking and personal hygiene, roof collected rainwater is considered to be a cold water service supplied by an alternative source.</p></intro-part><subtopic Buddy_ElementBookmark="Xpress_Internal_10" id="_5ea82beb-c9bf-462c-8553-f0f99b3066c0" subtopic-type="objective"><clauseref Buddy_ElementBookmark="Xpress_Internal_11" id="_578ea25d-128f-4371-98c0-31662068d97c" outputclass="clausref-ncc"><clause Buddy_ElementBookmark="Xpress_Internal_12" conref="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1711_1.3.0.xml" id="_9e460fc3-6d17-43f0-a182-9a79d3c97485" outputclass="ncc-clause"><sptc/><title id="_766eec10-064f-46f4-85cf-68b9138d4386"/></clause></clauseref></subtopic><subtopic Buddy_ElementBookmark="Xpress_Internal_24" id="_d12857b3-b156-4884-b060-7d19f3288a2d" subtopic-type="functional"><clau