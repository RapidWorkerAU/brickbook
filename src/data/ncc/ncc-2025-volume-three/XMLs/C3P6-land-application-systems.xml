<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_d2449b51-3abf-4179-a789-d53e6d075ea4" outputclass="ncc-clause"><sptc>C3P6</sptc><title id="_05edb39a-3f2d-491b-89ec-bee7ec32ce65">Land application systems</title><archive-num>New for 2022</archive-num><subclause id="_e38ecd38-ecb5-469a-959c-0ae239abb047" outputclass="subclause"><title id="_7f85df77-8d62-458a-8cc7-dafccacac5fe">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1383_4.5.0.xml#_2396187d-8435-4f01-9dfd-613970a74823" id="_90fdbdad-191c-4248-9c37-cc37159b6240" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">On-site wastewater management systems</xref> and associated land application systems must—</p><ol outputclass="alpha"><li id="_dc639c24-0106-4869-8b0b-d8615f816dbe">complete the treatment, uptake and absorption of the final effluent within the boundaries of the approved area; and</li><li id="_a61843bf-e129-4c6a-836f-3751c9fdd658">protect against internal contamination; and</li><li id="_62d85d17-a469-425e-bbab-bc5d77af7aa9">provide ventilation to avoid the likelihood of foul air and gases from accumulating in the system.</li></ol></subclause><subclause id="_32a62c7e-4411-402a-99ef-1568b6151c07" outputclass="subclause"><title id="_4a1e0ec0-1a43-4169-95ef-d40c08b54ca1">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1383_4.5.0.xml#_2396187d-8435-4f01-9dfd-613970a74823" id="_7ab8682f-a222-4b08-a455-3bc09fc70223" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">On-site wastewater management systems</xref> and associated land application systems must avoid the likelihood of—</p><ol outputclass="alpha"><li id="_9a33a807-8725-4abb-932c-8d2d6d1d1831">the creation of unpleasant odours or the accumulation of offensive matter; and</li><li id="_2311a70d-9840-4f36-afbf-1f2290593d6f">stormwater run-off entering the system; and</li><li id="_840726c2-345d-445a-8cb6-4b84bf87703a">root penetration or ingress of ground water entering the system; and</li><li id="_7181031a-7ba4-45a4-83e7-bd32e35da5f2">unintended or <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1500_27.0.0.xml#_0ece1af9-d663-4f17-a7c9-bf59ebb1b1ef" id="_c5d3de14-8024-4c00-be3c-4bb08843ad7e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">uncontrolled discharge</xref>; and</li><li id="_7525432e-ea94-418c-a67f-68ee663ed55e"><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1209_1.2.0.xml#_417d94d8-f254-4788-9a14-c4c5da89daa6" id="_222466bb-95ff-4aee-8777-6a4de84fd013" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">blockage</xref> and leakage; and</li><li id="_74fdd7e1-8e5b-44da-93cd-584ec1251e79">damage from superimposed loads or ground movement.</li></ol></subclause></clause>