<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_d82bc3be-bb8e-4bc9-83b8-19a49b088924" outputclass="ncc-clause" variation="TAS"><sptc>E4P2</sptc><title id="_e4b4980a-0b27-4c57-8eee-f89a91e91eca">Subsurface drainage</title><archive-num>2019: FP2.2</archive-num><subclause id="_3e68561a-a537-4d62-a278-05f78a009b78" outputclass="subclause"><title id="_cc5550eb-6e76-482b-8dd5-ed192d4d8e43">SubClause</title><num>1</num><p>A subsoil drainage system must remove excess groundwater and reduce soil moisture levels to prevent loss by changing soil moisture conditions.</p></subclause></clause>