<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_3a4761cd-b402-4418-8621-a213f8162258" outputclass="ncc-clause" variation="TAS"><sptc>E3F1</sptc><title id="_b119c9ae-8a74-4a1c-be58-61a52f3af4ec">Functional statements</title><archive-num>2019: FF01</archive-num><subclause id="_6e438137-bd1f-41e5-b3d9-360f7f26453d" outputclass="subclause"><title id="_93466d10-7953-4494-afa8-36a8488bab0c">SubClause</title><num>1</num><p>Buildings are to be provided with roof drainage to provide protection to people, property and the environment from adverse effects of stormwater.</p></subclause></clause>