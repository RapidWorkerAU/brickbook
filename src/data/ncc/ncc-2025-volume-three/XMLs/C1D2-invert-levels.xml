<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_4411813e-5b90-4827-83a3-b0283be7d644" outputclass="ncc-clause"><sptc>C1D2</sptc><title id="_2e3e7b85-da38-4111-b294-5213a573f62e">Invert levels</title><archive-num>2019: C1.2</archive-num><subclause id="_3d43abf8-7e06-4221-954e-9ea8103db943" outputclass="subclause"><title id="_eb772f1f-7351-4ff3-bc4e-b9799c981811">SubClause</title><num>1</num><p>The invert level of a trap or gully weir must be a minimum of 10 mm higher than the soffit of the pipe to which it connects.</p></subclause></clause>