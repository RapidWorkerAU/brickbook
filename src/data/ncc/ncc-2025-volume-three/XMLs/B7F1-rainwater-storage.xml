<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_0a06d325-68df-433b-a357-4e701fff6ed6" outputclass="ncc-clause"><sptc>B7F1</sptc><title id="_19e3f58a-9b21-4598-ad2e-7952f0ec8cc0">Rainwater storage</title><archive-num>2019: BF6</archive-num><subclause id="_0800a84d-46e8-4e4a-bc3f-3b82d3c96a99" outputclass="subclause"><title id="_41cb4cb4-1d83-4e54-af0a-93bcccdeda46">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/4891_0.8.0.xml#_a8d909a0-d649-477d-a969-848c9187c05d" id="_9fb9717a-821a-4f8d-ba4a-d07ed21e4fbb" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Rainwater storage</xref> systems must be designed and installed so as to operate in a way that avoids the likelihood of inadvertent contamination of any <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_11051130-6b01-4b88-838d-35e778a49746" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drinking water</xref> service, and minimises any adverse impact on building occupants, the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1376_4.2.0.xml#_12d6153c-4986-4856-80c0-e21bb57af12f" id="_1ba21147-3426-45aa-bea6-4690d0f4d479" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Network Utility Operator's</xref> infrastructure, property and the environment.</p></subclause></clause>