<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_09dbb141-6e56-42e6-9d30-7020ca1baba0" outputclass="ncc-clause" variation="SA"><sptc>C3D7</sptc><title id="_edcf0100-104b-4f36-8b39-eeaed420bd59">Common effluent drainage systems</title><archive-num>New for 2022</archive-num><subclause id="_3fcc0375-19f8-407f-ab9c-c597dade9966" outputclass="subclause"><title id="_b215fb4a-4b84-4ea4-a55d-096f2d04fdd0">SubClause</title><num>1</num><p>A common effluent drainage system must be in accordance the South Australia Community Wastewater Management Systems Code.</p></subclause></clause>