<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_c56b7cc6-9654-4347-9121-ad18d81c5446" outputclass="ncc-clause"><sptc>B7P1</sptc><title id="_fbca8843-df94-4ced-9cbc-db87988d5b31">Contamination</title><archive-num>2019: BP6.1</archive-num><clause-variation href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10753_0.5.0.xml" variation="TAS" variation-type="REPLACE">TAS REPLACE Clause</clause-variation><subclause id="_47bc6487-2b2c-4f28-a229-7057b2171656" outputclass="subclause"><title id="_bcfbe5ae-f6e4-42bf-a331-0bfda3aa74f6">SubClause</title><num>1</num><p>Rainwater must be stored in a way that reduces the likelihood of contamination.</p></subclause><subclause id="_f91c0589-3129-4d5d-a54b-7f0a70953f3d" outputclass="subclause"><title id="_5060f523-1ad3-4026-819d-26f374845a59">SubClause</title><num>2</num><p>Stored <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/9471_0.4.0.xml#_13115a1a-3513-4393-a7b2-4d6cfeb13be0" id="_b6e09079-4433-4f83-8f1d-995cd467e25e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">rainwater</xref> must not pose a hazard to public health.</p></subclause><callout id="_27eb5fce-3b5d-48a4-aaa3-31a13d7cbd62"><callout-type ncc-info-type="exemption"/><p>B7P1 does not apply to <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1463_0.4.0.xml#_fb3536f6-7ee5-4a29-a4da-402a8e1168dc" id="_adf129ac-2b62-42d0-8ca5-f28f05d691c8" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">sites</xref> not provided with a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_ff074ad2-7189-4144-964b-f86e71613037" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drinking water</xref> service by a <x