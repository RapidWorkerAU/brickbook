<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_406689b7-8754-4414-b629-aede0da02753" outputclass="ncc-clause" variation="NSW"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>G1D6</sptc><title id="_f99355e1-830c-477c-bf92-17401cd733ad">Cleaning windows</title><archive-num>2019: NSW G1.101</archive-num><subclause id="_f0534b7d-ad92-4c99-a7d9-e75380c5c8ed" outputclass="subclause"><title id="_10f1a5fa-d2cc-4c25-b81d-907cdca1284f">SubClause</title><num>1</num><p>A building that includes <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1525_29.1.0.xml#_48631093-d96b-4a40-a86d-7ffae028f24d" id="_beabd593-ca5c-4b3b-a30e-1c2b3729a6f5" scope="local" type="abcb-glossentry">windows</xref> located 3 or more <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1483_25.0.0.xml#_53ff3ea1-55e7-4f2a-b2b3-ca445ff64c15" id="_2d0c5307-b5ea-4be4-a8ce-5ee1d97405ec" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">storeys</xref> above ground level satisfies <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_a133895a-d762-477b-82d1-89599add8100" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Performance Requirement</xref> <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10649_0.2.0.xml#_37a91cb7-cf05-4284-bc76-9528db59a914" id="_f977570a-c646-4ecf-9e11-155dd5a0217f" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW G1P6</xref> where—</p><ol outputclass="alpha"><li id="_6006ced3-7254-4c7e-b95a-da0b9c65c1c1">the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1525_29.1.0.xml#_48631093-d96b-4a40-a86d-7ffae028f24d" id="_dca9522a-e565-4ce2-baae-ca2047b9c1df" scope="local" type="abcb-glossentry">windows</xref> can be cleaned wholly from within the building; or</li><li id="_fe0f6c9c-4a93-483b-bef0-89ead70d7d6c">provision is made for the cleaning of the <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1525_29.1.0.xml#_48631093-d96b-4a40-a86d-7ffae028f24d" id="_ca57d3b8-cf91-4ad4-80f0-2dd37448b384" scope="local" type="abcb-glossentry">windows</xref> by a method complying with the Work Health and Safety Act 2011 and Regulations made under that Act.</li></ol></subclause></clause>