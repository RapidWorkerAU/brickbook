<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_25c30fc8-820a-4451-b9f1-5d334af62f83" outputclass="ncc-clause"><sptc>B2P12</sptc><title id="_881e43d3-ccb6-4338-8939-7abc35705655">Water efficiency</title><archive-num>New for 2022</archive-num><clause-variation href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/10657_0.2.0.xml" variation="NSW" variation-type="REPLACE">NSW REPLACE Clause</clause-variation><subclause id="_189a3cac-67c4-4302-9d63-afdef385a087" outputclass="subclause"><title id="_27812ffc-040b-426d-ba5c-376d9d06c9af">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_79a7a898-7cf4-47df-8c64-d2361fd3f73c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heated water</xref> service must ensure the efficient use of <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_f9136f3f-9075-4355-b302-ffa979e8c0f9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">drinking water</xref> by limiting water use from a tap or outlet for a shower, basin, kitchen sink or laundry trough to a flow rate of not more than 9 l/m.</p></subclause></clause>