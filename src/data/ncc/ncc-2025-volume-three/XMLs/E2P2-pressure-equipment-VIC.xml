<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_4c52ff9f-e3b5-478a-a4b6-ecc3d63ebfeb" outputclass="ncc-clause" variation="VIC"><sptc>E2P2</sptc><title id="_b0d6fa2a-cc57-4c7a-ab76-b482a0517524">Pressure equipment</title><archive-num>2019: GP1.2</archive-num><subclause id="_f7c3e5e6-e54c-4c9a-b18a-74cc3cb5757f" outputclass="subclause"><title id="_b47291ed-0beb-454b-aa47-83172ac182bb">SubClause</title><num>1</num><p>Pressure equipment used in mechanical heating, cooling or ventilation systems must avoid the likelihood of explosion, rupture or leakage.</p></subclause></clause>