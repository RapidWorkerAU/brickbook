<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_b3f5dc54-a238-4ff0-916f-0b4cbdb1f106" outputclass="ncc-clause"><sptc>B2P1</sptc><title id="_49ae535d-1e25-447f-b1c9-db0d46574473">Heated water supply</title><archive-num>2019: BP2.1</archive-num><subclause id="_3ac96003-a120-47b2-abe7-5554e2a9a2c9" outputclass="subclause"><title id="_d1705906-0f0a-4376-9052-75c2d4d9ea08">SubClause</title><num/><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_90351cb3-253b-4905-a3a5-406224cc6e90" scope="local" type="abcb-glossentry">heated water</xref> service must be connected to a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_c60589d4-e1b0-4c60-b2f8-b516db3445e0" scope="local" type="abcb-glossentry">drinking water</xref> supply.</p></subclause><callout id="_da765ec7-de9f-4ffa-b2e6-9c146dc2213c"><callout-type ncc-info-type="application"/><p>B2P1 applies to a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_3eb49ba5-157a-4de9-bb20-a9d41864112a" scope="local" type="abcb-glossentry">heated water</xref> service used for human consumption, food preparation, food utensil washing or personal hygiene.</p></callout></clause>