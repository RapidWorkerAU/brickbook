<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_cf056745-8aad-41f0-9ec3-5961162eb7b0" outputclass="ncc-clause"><sptc>C1P2</sptc><title id="_b47f92a0-8018-4b1b-9275-640016e02fde">Access</title><archive-num>2019: CP1.1</archive-num><subclause id="_9d4a91ce-cc56-4f04-bffa-220471bc0c03" outputclass="subclause"><title id="_d1b4e786-640d-41bc-8071-3b61a9c478e5">SubClause</title><num>1</num><p>Access must be provided to components of a sanitary <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1401_0.7.0.xml#_a318c0f3-5635-4ac0-b103-59d798c9f23d" id="_5609ea83-1529-434d-9204-9c7237e394a9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">plumbing</xref> system that require maintenance or replacement including mechanical devices, controls and for clearing <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1209_1.2.0.xml#_417d94d8-f254-4788-9a14-c4c5da89daa6" id="_b0699134-4048-448c-ac97-fef3776a2e5f" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">blockages</xref>.</p></subclause><callout id="_a9239b9a-d05a-4b52-be13-5718639f6231"><callout-type ncc-info-type="info"/><p>Access to mechanical components may require removal of an access panel, cover, door, or similar obstruction.</p></callout></clause>