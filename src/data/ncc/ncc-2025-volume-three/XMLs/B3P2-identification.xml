<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_35088b5f-41e0-4277-bc5f-2a5178d09257" outputclass="ncc-clause"><sptc>B3P2</sptc><title id="_568dc57e-8107-41e2-bc4c-2a4498860db9">Identification</title><archive-num>2019: BP3.2</archive-num><subclause id="_63b6867a-bbbe-496c-b4d8-62dc2d4d2f84" outputclass="subclause"><title id="_fdea965b-c9f0-4f64-a400-a41715c43fa7">SubClause</title><num>1</num><p>Pipes, outlets, fittings, storage and holding tanks that are part of a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1378_4.3.0.xml#_cfc4fec0-3cb7-41d6-b176-4a92d4cdb221" id="_cb124b68-15f2-4e9a-8f87-3dd053b3ba5a" scope="local" type="abcb-glossentry">non-drinking water</xref> service must be clearly identified.</p></subclause><subclause id="_6ba0ec0b-e1d0-492c-beba-043d0f11f2a0" outputclass="subclause"><title id="_1e55bff4-9ba0-45c2-b25c-cd6416b1a181">SubClause</title><num>2</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1378_4.3.0.xml#_cfc4fec0-3cb7-41d6-b176-4a92d4cdb221" id="_215b08c1-dc76-4ba9-97dd-6d24c79f4d4e" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">non-drinking water</xref> service must only be connected to outlets clearly identified for non-drinking use.</p></subclause></clause>