<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_fec7aabe-a8b8-4c60-a9b3-74327f4d9d8c" outputclass="ncc-clause"><sptc>B2P2</sptc><title id="_478e8043-a0d7-4834-ad72-bb00efd1b7c6">Scald prevention</title><archive-num>2019: BP2.2</archive-num><subclause id="_c2e194a7-07a3-407d-ace7-a26ba950f6da" outputclass="subclause"><title id="_0e9044ad-c72b-4a42-a55f-0c2f355071f2">SubClause</title><num>1</num><p><xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_2d82c815-01d8-4b4b-8563-231d50c0544d" scope="local" type="abcb-glossentry">Heated water</xref> supplied by a <xref format="dita" href="/tmp/QppServer/Publishing/1c3f2f74-4ee1-4cdd-b1b4-53c91069d002/1334_0.4.0.xml#_92b3a3dc-59e4-425f-909b-d8eb03e6460a" id="_6a7afdce-22e1-4db8-ba47-1209ac6b0f83" scope="local" type="abcb-glossentry">heated water</xref> service must be delivered from the point of discharge of fixtures and appliances at a temperature which is unlikely to scald.</p></subclause><callout id="_a6decf46-fb2a-48ff-baf4-3b137c892c27"><callout-type ncc-info-type="application"/><p>B2P2 applies to fixtures and appliances used primarily for personal hygiene.</p></callout></clause>