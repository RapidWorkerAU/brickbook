<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_1ddda445-0168-41be-bcbc-927b605b5b8e" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10a"/><facet building="Class 10b"/></meta><sptc>H7F5</sptc><title id="_875bc4dd-661a-475a-85d0-3420560974d8">Private bushfire shelters</title><archive-num>2019: F2.7.5</archive-num><subclause id="_e1f84b9b-7ced-424e-ada9-9eb019270914" outputclass="subclause"><title id="_544a5970-2cb2-4a81-9f59-83bdf8f7ad73">SubClause</title><num>1</num><p>A structure designed for emergency occupation during a bushfire event must provide shelter to occupants from direct and indirect actions of a bushfire.</p></subclause><callout id="_965cf58c-d244-4d57-82b5-1cbf430dff12"><callout-type ncc-info-type="application"/><p>H7F5 only applies to a Class 10c building.</p></callout></clause>