<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_c52881a5-38ff-4b1f-b32b-d68bada738c8" outputclass="ncc-clause" variation="SA"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>H10O1</sptc><title id="_d7ba665e-694e-40ec-9ce0-dc5ff8575282">Objective</title><archive-num>2019: SA 5.1</archive-num><subclause id="_a4c347ad-14c3-4cd8-8179-769fce0de27d" outputclass="subclause"><title id="_14858cf9-10b2-4ab7-bbce-54158f46f4da">SubClause</title><num>1</num><p>Provide, as far as is reasonable, people with safe, equitable and dignified access to a degree necessary to—</p><ol outputclass="alpha"><li id="_dd11bb28-fabd-473f-86de-472123de97e7">buildings; and</li><li id="_66469e31-8a4d-4513-98da-c176ef8ebb30">the services and facilities within.</li></ol></subclause><callout id="_0051de5b-cd95-4f95-bca3-07cee3fda7c3"><callout-type ncc-info-type="application"/><p>SA H10O1 applies to Class 1 buildings in developments of 20 or more dwellings.</p></callout></clause>