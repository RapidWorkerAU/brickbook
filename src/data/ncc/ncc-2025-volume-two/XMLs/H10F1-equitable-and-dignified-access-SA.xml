<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_4a5be99a-d89f-4c7b-a7d1-7e2134997478" outputclass="ncc-clause" variation="SA"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>H10F1</sptc><title id="_0bbc2acc-e636-40c2-9633-9ecdaab9c4e0">Equitable and dignified access</title><archive-num>2019: SA 5.1</archive-num><subclause id="_7b054778-36fa-4c40-9547-65c709a335dd" outputclass="subclause"><title id="_3998aba4-c233-4a4f-afea-7d6918da47f5">SubClause</title><num>1</num><p>A building to the degree necessary is, as far as is reasonable, to provide safe, equitable and dignified access for people to the services and facilities within.</p></subclause><callout id="_6670f427-cde3-4685-9089-99d9b0f6cc5b"><callout-type ncc-info-type="application"/><p>SA H10F1 applies to Class 1 buildings in developments of 20 or more dwellings.</p></callout></clause>