<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:qxa="urn:schemas-quark-com:xmlauthor" id="_1d88340a-a359-4632-9d9f-d3a0fa304d0e" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>H6V2</sptc><title id="_4b2adb5a-0ffa-493f-9609-c17729e1a400">Verification using a reference building</title><archive-num>2019: V2.6.2.2</archive-num><clause-variation variation="NSW" variation-type="DELETE">NSW DELETE Clause</clause-variation><subclause id="_8e579928-390c-49fe-99f5-af3beca0703d" outputclass="subclause"><title id="_c236dc79-a99d-4868-9838-43866cf06198">SubClause</title><num>1</num><p>Compliance with <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1946_3.17.0.xml#_ebeae85f-b094-4bad-a411-364a0334aa3b" id="_2fed96a5-4fc8-4bde-82b7-d22fe2695ab3" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">H6P1</xref> is verified when a proposed building—</p><ol outputclass="alpha"><li id="_fff98a31-8302-4143-a166-48993abc1e16">compared to a <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_fc475391-c121-4518-9257-3a107e2e0ca2" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref>, using a calculation method other than <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1342_0.23.0.xml#_c3e52045-6061-460e-93b7-bf5293430c15" id="_429635da-9c8d-47c1-be65-52c9901703a1" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">house energy rating software</xref>, has—<ol><li>in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_4c5c146c-70f5-4779-843b-e3687098d9c5" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 1, a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1231_0.6.0.xml#_472a0fb8-883e-4d81-8175-ccc758fa911f" id="_343923d3-1947-4de3-92f0-1b16a91b9baf" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cooling load</xref> equal to or less than that of the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_9328b3da-20c7-4640-826b-66c2d1b9f546" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref>; or</li><li>in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_7ed6667b-48f4-4b89-ab9d-3f428d185de5" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> 8, a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1335_0.4.0.xml#_4dc3aa38-1ac4-4ad8-92f1-c4c52e332554" id="_7f98e62e-6c61-42be-8090-9f2bd7db1f0a" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heating load</xref> equal to or less than that of the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_f12aaf1a-898c-4733-94d6-0abe5f57f254" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref>; or</li><li>in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_7ac481b6-0966-4b78-b1ea-141da741ac78" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 2, 3, 4, 5, 6 and 7, a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1335_0.4.0.xml#_4dc3aa38-1ac4-4ad8-92f1-c4c52e332554" id="_474b1b87-0fd6-4b20-a006-8cf906b6ba1c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heating load</xref> and a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1231_0.6.0.xml#_472a0fb8-883e-4d81-8175-ccc758fa911f" id="_5b67d61b-3d77-4234-a23e-81b3c7274627" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cooling load</xref> equal to or less than that of the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_a8d3cea3-713a-43a8-b1e3-6b834691499c" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref>; and</li></ol></li><li id="_a9e79f9d-6c80-4e56-b889-63bf2a306925">complies with—<ol><li>for building <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1269_0.5.0.xml#_13553d4f-118c-47e2-90ba-9892194abdf6" id="_0447ad19-c76c-45d3-94b2-47e4b270df1d" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">fabric</xref> thermal insulation, clause <xref format="dita" href="qpp://assets/2043#_e835680a-a71a-42c2-995e-0550abdf0eda" id="_139b5ca7-fa0a-4e93-8b57-4a1da7ef2678" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="ncc-clause">13.2.2</xref> of the ABCB Housing Provisions; and</li><li>for thermal breaks, clauses <xref format="dita" href="qpp://assets/2380#_079a5bf0-5e77-4d1f-aaf8-cf26070dc863" id="_10d84fe3-1246-482d-ba9a-833237dd9d7a" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="subclause">13.2.3(7)</xref> and <xref format="dita" href="qpp://assets/2382#_71c35b1d-29b9-40e3-8aa5-a2262f8ab1cb" id="_5624d998-92b5-4783-b3d3-d94297eb5f84" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="subclause">13.2.5(5)</xref> of the ABCB Housing Provisions; and</li><li>for floor edge insulation, clauses <xref format="dita" href="qpp://assets/2383#_4053b4dd-55b7-416b-9b91-1a3e5bc00799" id="_433d5f9a-076b-4274-9b97-a74c2e13ecd2" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="subclause">13.2.6(4)</xref>, <xref format="dita" href="qpp://assets/2383#_f1d24984-4b12-4e5b-a47c-2ab04938187b" id="_e3128287-e07b-41b4-8f76-25ff870068d9" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="subclause">13.2.6(6)</xref> and <xref format="dita" href="qpp://assets/2383#_d0dac61c-de5e-4fc2-9d81-6ca4982b3975" id="_5b91a7f9-3aef-4860-810b-761fc596f6c4" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="subclause">13.2.6(7)</xref> of the ABCB Housing Provisions; and</li><li>for building sealing, <xref format="dita" href="qpp://assets/4234#_09a0cfcb-49e7-4656-a327-9fbd0dbd1672" id="_38d996ce-ab0b-4593-8639-192e17bf101b" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.4</xref> of the ABCB Housing Provisions or <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1950_3.29.0.xml#_e2910350-9b01-4add-9eaa-efe6ecd991fe" id="_d3f7441c-4bd4-4f90-a489-53c5532960e5" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">H6V3</xref>.</li></ol></li></ol></subclause><subclause id="_8b965b8b-fae7-44db-bba1-0e20952765e8" outputclass="subclause"><title id="_fca4ed97-fde9-41d5-8478-1b596e25b943">SubClause</title><num>2</num><p>The <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_e191d7cd-1636-4480-99a4-fb41eb43cfa3" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref> must comply with the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1236_1.0.0.xml#_2f02788f-8757-4689-b36e-e44d96524cc9" id="_6fc4a2fd-21c6-496a-b6be-5273a78c107b" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Deemed-to-Satisfy Provisions</xref> in <xref format="dita" href="qpp://assets/4232#_72b51e96-6a69-494d-a889-b470cddec7f9" id="_56a88b13-d271-4bc9-80aa-c73336959a0f" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Parts 13.2</xref>, <xref format="dita" href="qpp://assets/4233#_057d2694-35fa-4a5e-88bd-fa309915541c" id="_556d91d4-fa24-464d-acc6-30bf046457df" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">13.3</xref> and <xref format="dita" href="qpp://assets/4235#_be12359c-d7ea-4891-bb18-343ba3471652" id="_c6949c47-b6b1-40b9-8228-fc31b1500a19" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">13.5</xref> of the ABCB Housing Provisions.</p></subclause><subclause id="_7ce989c7-b3fe-478b-9e5f-71280c8d38c2" outputclass="subclause"><title id="_47b1b3c1-9f01-4318-bb52-1639aee0bf63">SubClause</title><num>3</num><p>The <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1335_0.4.0.xml#_4dc3aa38-1ac4-4ad8-92f1-c4c52e332554" id="_231cf15e-87b5-4dc5-8bb3-141cb778d27f" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heating load</xref> and <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1231_0.6.0.xml#_472a0fb8-883e-4d81-8175-ccc758fa911f" id="_39c14249-8624-4e96-880b-cc490ac4b4fe" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cooling load</xref> for the proposed building and the <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1424_4.10.0.xml#_5dfc40fe-dad0-46ab-9923-f7643beb2160" id="_5354ad31-b275-44d5-8788-606a45aebee2" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">reference building</xref> must be determined using the same—</p><ol outputclass="alpha"><li id="_87c5d5af-d80f-49ac-bce4-909b32ed259b">calculation method; and</li><li id="_cea49041-e61a-4a0c-b102-ac384c10e001">location specific data, including that of climate and topography appropriate to the location where the proposed building is to be constructed if the data is available, or the nearest location with similar climatic conditions in the same <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_bcbef16d-ecbd-4deb-9ca2-9bb6e8cf4e93" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zone</xref> for which the data is available; and</li><li id="_ae12826d-66d8-40b7-b691-21817c68a3ea">impact of adjoining structures and features; and</li><li id="_8957e4fc-aea8-4a8d-8264-455fb80a984d">soil conditions; and</li><li id="_b4f58d8e-bbaa-426a-9e96-76e885c1813b">orientation; and</li><li id="_63274064-cabd-4a61-9573-4e6076a5c2fa">floor plan, including the location and size of <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_f8ae47b4-6080-426a-9328-c355e89a1777" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref>; and</li><li id="_a94c8b8e-c499-476c-81de-76f692ad4b4b">number of storeys; and</li><li id="_5ccb30c1-e015-4691-9cbd-765434b4cd94">roof cladding and <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1441_5.5.0.xml#_12b88f11-1c3d-4d91-bc65-02588a4dc524" id="_059b856c-8bec-45ea-b4b3-3a5bd64cd601" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">roof lights</xref>; and</li><li id="_5a7ff570-7034-4e5a-9618-809cf8519d3a">separating walls; and</li><li id="_34fd5ab3-9133-43bd-b51b-458dffffec14">external non-glazed doors; and</li><li id="_e33bcdbc-4a19-4410-b51c-34b8841ac5d1">intermediate floors; and</li><li id="_e06bad9d-722c-44e9-af8c-8a3d989b329a">floor coverings; and</li><li id="_98fed1b9-1ebc-46e0-bc28-2d48790f4457">ventilation; and</li><li id="_d92aa64b-02b7-4670-90cf-60c7be4ef03a">function and use of the building and spaces, including zoning and hours of occupation; and</li><li id="_602d73f0-6d34-4d59-b843-bf151de5ff3a">operating schedules for heating and cooling in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6292_0.6.0.xml#_f891997f-3522-49e5-9809-b533bfbfcce7" id="_cf1d840b-655e-4fbe-969c-7a637387f582" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table H6V2a</xref>; and</li><li id="_dbfc9688-15b7-49a2-8938-3649037accb6">cooling thermostat settings of—<ol><li>for bedrooms, 24°C; and</li><li>for <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1326_0.4.0.xml#_b8eec66f-9c05-425d-8474-e6a2dfc2c0f4" id="_103714a9-8216-4e0c-a409-1d2fd298fc52" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">habitable rooms</xref> other than bedrooms—<ol><li>in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_5d39a4bb-8560-404e-95d1-6fe2f45345f4" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 1, 2, 3 and 4, 27°C; and </li><li>In <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1458_0.16.0.xml#_0d25cef7-0651-40ea-a0e6-3d3db1191e24" id="_a14853a0-7f5a-4091-8251-63290df02e90" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">climate zones</xref> 5, 6, 7 and 8, 26°C; and</li></ol></li></ol></li><li id="_f1b38a56-d5c1-4bd1-87a3-8e7ea6dcfc7e">heating thermostat setting of 20°C for all <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1326_0.4.0.xml#_b8eec66f-9c05-425d-8474-e6a2dfc2c0f4" id="_1f167a5c-8c46-4f3f-ad97-f39277a0d296" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">habitable rooms</xref>; and</li><li id="_e1feb1cc-cdec-47fb-a500-74332e6d9a9a">occupancy in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6295_0.8.0.xml#_569f4f8d-a175-4393-a667-7df034747064" id="_8c219a5b-8faf-4d3f-9042-def6cc350b5f" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table H6V2b</xref>, with —<ol><li>heat gains due to occupants of—<ol><li>75 W per person in bedrooms; and</li><li>105 W per person in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1326_0.4.0.xml#_b8eec66f-9c05-425d-8474-e6a2dfc2c0f4" id="_8d0ef9a0-9d11-4c93-9db8-7b4ed6067ab6" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">habitable rooms</xref> other than bedrooms; and</li></ol></li><li>occupancy schedules in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6297_0.7.0.xml#_4edf58e0-8b56-485e-bd6c-0c6407a5c361" id="_dd5c666a-59f6-468d-a09d-84e83c7bdcf1" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table H6V2c</xref>; and</li></ol></li><li id="_c6e9a0ee-669f-42a3-9d0b-6664d993c5e1">internal heat gains—<ol><li>from appliances, 450 W; and</li><li>from lighting, 4 W/m²; and</li><li>from cooking equipment, in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6295_0.8.0.xml#_569f4f8d-a175-4393-a667-7df034747064" id="_fa10b686-6bc0-4752-b399-6e044ee659a5" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table H6V2b</xref>; and </li><li>using the operating schedules for lighting, cooking equipment and appliances, in <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6300_0.7.0.xml#_b7377eea-6c5b-4427-bbc7-c10b33ef8123" id="_0c50cf64-8057-4606-9adb-16fdabf3ba8b" referencetype="Text" scope="local" synctargettext="false" type="table-reference">Table H6V2d</xref>; and</li></ol></li><li id="_d14f4565-7570-4358-b1ab-b65d40026fea">air infiltration rate—<ol><li>of 0.75 air changes per hour; or</li><li>equal to the intended building air change rate at 50 Pa, divided by 20, where—<ol><li>an intended building air change rate at 50 Pa is specified; and</li><li>additional building sealing provisions to <xref format="dita" href="qpp://assets/4234#_09a0cfcb-49e7-4656-a327-9fbd0dbd1672" id="_96d6012b-e871-4c30-8a05-a7dba41b21d8" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.4</xref> of the ABCB Housing Provisions are specified; and</li><li>building sealing is verified using <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1950_3.29.0.xml#_e2910350-9b01-4add-9eaa-efe6ecd991fe" id="_e36a864a-4616-4ae0-8d76-4508dc869eef" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">H6V3</xref>.</li></ol></li></ol></li></ol></subclause><subclause id="_a1935d0c-f369-4454-957d-7498ff97d0d0" outputclass="subclause"><title id="_990f25bc-3d4f-465f-a8dc-9ecd47c3a9f8">SubClause</title><num>4</num><p>The calculation method used must comply with ANSI/ASHRAE Standard 140 and be capable of assessing the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1335_0.4.0.xml#_4dc3aa38-1ac4-4ad8-92f1-c4c52e332554" id="_5e5f0984-f948-4f10-8205-7142ba0088fd" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heating load</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1231_0.6.0.xml#_472a0fb8-883e-4d81-8175-ccc758fa911f" id="_0fb4c11e-f450-44e1-a6d1-bf17213317e7" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cooling load</xref> by modelling—</p><ol outputclass="alpha"><li id="_de8a88cd-7a6d-4ae5-ba03-aed8b0bddde1">the building <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1269_0.5.0.xml#_13553d4f-118c-47e2-90ba-9892194abdf6" id="_717b6142-5472-47d7-be89-02c58ab124d1" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">fabric</xref>; and</li><li id="_e8237e47-502e-46e6-bfdb-3709bd055ff7"><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_5bb96f2d-e275-4cd4-bffe-014c7801ca65" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref> and shading; and</li><li id="_4546529f-cb16-48ca-9a27-242ba1d94c2f">air infiltration and ventilation; and</li><li id="_dd27d7ec-4453-4f27-93b9-0d2733fdc957">the function and use of the building including zoning, hours of occupation, hours of heating and cooling availability and internal heat gains; and</li><li id="_814837bc-73a4-4052-9d56-3913f4fbe16e">relevant built-environment and topographical features; and</li><li id="_b071711c-5b23-4510-9bc7-c9a9f71f4d70">the sensible heat component of the <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1231_0.6.0.xml#_472a0fb8-883e-4d81-8175-ccc758fa911f" id="_0f0f9881-ae52-40c0-a6e6-506ef3f19f5a" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">cooling load</xref> and <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1335_0.4.0.xml#_4dc3aa38-1ac4-4ad8-92f1-c4c52e332554" id="_dc877eda-a858-44a1-a16f-eea46b7af891" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">heating load</xref>.</li></ol></subclause><subclause id="_ff229383-8377-4c0e-a51a-2f560dc94655" outputclass="subclause"><title id="_0ad52364-2213-4ebb-a4e6-cb530de70dcd">SubClause</title><num>5</num><p>Climatic data employed in the calculation method must be based on hourly recorded values and be representative of a typical year for the proposed location.</p></subclause><table-reference conref="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6292_0.6.0.xml" graph="None" id="_f891997f-3522-49e5-9809-b533bfbfcce7"><num>H6V2a</num><title id="_b68d05ae-12b0-4947-8f62-bfd667572a31">Heating and cooling schedules</title><table id="_7ca40740-a69a-4936-b6f2-ce98b0474e9c" keycol="1"><tgroup cols="3"><colspec colname="001" colnum="1" colwidth="143.95*"/><colspec colname="002" colnum="2" colwidth="196.55*"/><colspec colname="003" colnum="3" colwidth="91.50*"/><thead><row><entry