<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_254d0e6b-cca2-40f7-bc77-4b4b7e82c1cf" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>H4O7</sptc><title id="_37314b51-562b-4655-a8a0-449619f9a867">Condensation and water vapour management</title><archive-num>New for 2022</archive-num><subclause id="_57d6394c-4116-431a-be51-d528f79c83ac" outputclass="subclause"><title id="_66ee7188-1e9b-4fb7-a45e-b57a297e3f5f">SubClause</title><num>1</num><p>The Objective is to reduce the likelihood of <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1224_0.8.0.xml#_7bd3fe3a-8528-4438-a6cb-6f4b43993774" id="_65e167a2-4e93-4765-85b1-f5dbf6cf3704" scope="local" type="abcb-glossentry">condensation</xref> or water vapour build-up causing illness, injury or loss of <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1186_0.6.0.xml#_905252bf-2ff1-43f8-ae81-2949aa116fee" id="_9a3b0203-9b78-454a-9cfd-d75d367e67ae" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">amenity</xref> for building occupants.</p></subclause><callout id="_c786e937-c637-4f7f-906c-dd1dfdb607fa"><callout-type ncc-info-type="application"/><p>H4O7 only applies to a Class 1 building.</p></callout></clause>