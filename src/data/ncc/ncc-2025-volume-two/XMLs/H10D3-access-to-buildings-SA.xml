<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_580774ad-ea5e-4727-a0f3-85ad93d67477" outputclass="ncc-clause" variation="SA"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>H10D3</sptc><title id="_a0a1d7fc-b290-4c19-bdf8-30fa6d6daa2c">Access to buildings</title><archive-num>2019: SA 5.2.2</archive-num><subclause id="_5848b21d-6541-46af-8d58-737ed2ac8dac" outputclass="subclause"><title id="_aa1a4b42-88e8-4dc1-9e0e-72353cf9605c">SubClause</title><num>1</num><p>In developments consisting of 20 or more dwellings, access must be provide to and within one dwelling or 5% of the total number of dwellings, whichever is the greater.</p></subclause></clause>