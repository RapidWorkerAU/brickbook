<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_9dad7301-0c09-495c-8e8e-94653b60c8fb" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/></meta><sptc>H2D4</sptc><title id="_5d576eab-0e86-4731-b857-63c68a4eac97">Masonry</title><archive-num>2019: 3.3.4</archive-num><subclause id="_72887e5a-80b0-4ed4-b9e5-0fabce7d3d11" outputclass="subclause"><title id="_12e28803-c9cc-4b84-861f-aaf2eda2ec70">SubClause</title><num>1</num><p>H2D4(2)—</p><ol outputclass="alpha"><li id="_4fd9b63d-124c-46fe-838d-86f50c633a9b">applies to every <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1267_2.3.0.xml#_d87c7cc0-d0b0-40ab-9a5b-d070ed6e115e" id="_9f3b8824-46eb-4635-b5df-66b94e21206f" scope="local" type="abcb-glossentry">external wall</xref> (including the junction between the wall and any <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1525_29.1.0.xml#_48631093-d96b-4a40-a86d-7ffae028f24d" id="_8fbc3681-5daf-463f-a609-d8f16439af03" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">window</xref> or door) of a Class 1 building; and</li><li id="_bd61ec92-166e-44f9-ad84-90b7a431980b">does not apply to any Class 10 building except where its construction contributes to the weatherproofing of the Class 1 building.</li></ol></subclause><subclause id="_801fe0be-9bf4-40e3-8dac-51120f6b4963" outputclass="subclause"><title id="_edcf576b-f0b6-4088-8711-c979d6db635a">SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_ebbd8af0-3216-4324-937e-9bd26b211aef" scope="local" type="abcb-glossentry">Performance Requirements</xref> <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1829_2.4.0.xml#_c78db730-5473-4624-a33f-2237c86f4944" id="_da89b4fe-df75-4ebe-a22b-35c1f9f81ea5" scope="local" type="clause">H2P2</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1830_0.11.0.xml#_35c06f06-a2af-4d1a-aa19-05110f4dc594" id="_2025274d-7d21-4aec-9828-1cebfaeddb27" scope="local" type="clause">H2P3</xref> are satisfied for weatherproofing of masonry if it is carried out in accordance with the appropriate provisions of one of the following:</p><ol outputclass="alpha"><li id="_7c88d53e-52d2-44ab-9378-b91e0457db09">AS 3700.</li><li id="_831f8dae-ca75-407e-9052-deab6f53d608">AS 4773.1 and AS 4773.2.</li><li id="_ea408850-39d2-458c-9d7a-df8fd0e0f725"><xref format="dita" href="qpp://assets/4861#_cb710dc2-ce1b-4bd2-bfd8-108e8306e5d2" id="_6a4410e5-7ecf-41c3-abee-309a630ce016" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 5.7</xref> of the ABCB Housing Provisions provided masonry walls are constructed in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1807_2.27.0.xml#_c1e7a2da-3ebf-4007-9f08-134efafe0279" id="_1d7f545b-ca88-4840-9888-39994c8c02ab" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">H1D5</xref> and the requirements of <xref format="dita" href="qpp://assets/4861#_cb710dc2-ce1b-4bd2-bfd8-108e8306e5d2" id="_be763837-7b77-4b6d-8b2c-630e24ddd9a9" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 5.7</xref>.</li></ol><subclause id="_fae29622-4a70-4195-b48a-612dad6f2154" outputclass="state-variation" variation="NSW" variation-type="REPLACE"><title id="_f3747698-04af-417b-bb92-7b2ce7465bd0">NSW REPLACE SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_a465b9b0-a33c-4134-9f20-d3e62d432de3" scope="local" type="abcb-glossentry">Performance Requirements</xref> <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1829_2.4.0.xml#_c78db730-5473-4624-a33f-2237c86f4944" id="_6d38ee9a-68ce-4333-8e7e-9875069aa876" scope="local" type="clause">H2P2</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/2049_0.7.0.xml#_f8724c0e-0744-4c0f-bee9-a043e1a5f536" id="_5a654729-d290-4e06-b83e-7c8bbf9f46ee" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">NSW H2P3</xref> are satisfied for weatherproofing of masonry if it is carried out in accordance with the appropriate provisions of one of the following:</p><ol outputclass="alpha"><li id="_12b34169-4260-4517-b162-3bf22fddc258">AS 3700.</li><li id="_47963c36-3662-49f6-85f3-2fd6c1cfdcdb">AS 4773.1 and AS 4773.2.</li><li id="_f85f827b-c06f-4c94-9be2-ab734c84f9c7"><xref format="dita" href="qpp://assets/4861#_cb710dc2-ce1b-4bd2-bfd8-108e8306e5d2" id="_0fa99ccb-76d3-4c21-8a63-16dd20215889" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 5.7</xref> of the ABCB Housing Provisions provided masonry walls are constructed in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1807_2.27.0.xml#_c1e7a2da-3ebf-4007-9f08-134efafe0279" id="_8b79378c-847c-4fc5-9e56-7bc3b3e56de0" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">H1D5</xref> and the requirements of <xref format="dita" href="qpp://assets/4861#_cb710dc2-ce1b-4bd2-bfd8-108e8306e5d2" id="_7bb04595-93e7-44e4-88eb-c43fb520c9ce" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 5.7</xref>.</li></ol></subclause><subclause id="_a283a340-d332-42a8-9e8e-ec9ddbeb7637" outputclass="state-variation" variation="SA" variation-type="REPLACE"><title id="_e7a8df46-73e9-4bb1-81d6-0881d58b5bb7">SA REPLACE SubClause</title><num>2</num><p><xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_1701cd31-3169-47c9-b8fd-604c5091183b" id="_459ba33e-0616-4ffe-97e1-660a3ad19e3c" referencetype="Text" scope="local" synctargettext="false" type="glossterm">Performance Requirements</xref> <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1829_2.4.0.xml#_c78db730-5473-4624-a33f-2237c86f4944" id="_a0d26ecc-f74c-49fa-b024-e14ee394742e" scope="local" type="clause">H2P2</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1830_0.11.0.xml#_35c06f06-a2af-4d1a-aa19-05110f4dc594" id="_f8a8efa8-ca02-4692-9c7c-798197b1f6fb" scope="local" type="clause">SA H2P3</xref> are satisfied for weatherproofing of masonry if it is carried out in accordance with the appropriate provisions of—</p><ol outputclass="alpha"><li id="_f622a9ad-920a-4a34-82c8-7f37ca359780">AS 3700 - Masonry structures; or</li><li id="_3403ceb6-0921-4d78-991c-9ca0890ac15d">AS 4773 - Masonry for small buildings, Parts 1 and 2.</li></ol></subclause></subclause><subclause id="_e8748562-4b31-4d7a-baca-166ba3f53d50" outputclass="state-variation-insert" variation="SA" variation-type="INSERT"><title id="_91d198d0-37a6-435b-b9ae-748550266c08">SA INSERT SubClause</title><num>3</num><p>For the purposes of <xref format="dita" href="#_e7a8df46-73e9-4bb1-81d6-0881d58b5bb7" id="_2f047d99-acd2-4a6d-b28a-dae42837ef28" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">SA H2D4(2)</xref>, metals and bitumen-coated metals referred to in clauses 7.2. and 7.3 of AS/NZS 2904 are not acceptable materials for use as <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1235_0.7.0.xml#_2c1e6053-5ce4-447e-965e-b393cf19b5ba" id="_f6dcb64a-999a-46dd-96ee-7c5bc7ea5ccb" referencetype="Text" scope="local" synctargettext="false" type="glossterm">damp-proof courses</xref> in South Australia.</p></subclause><subclause id="_3782ff65-6856-4d20-9860-721a3e1701cc" outputclass="state-variation-insert" variation="SA" variation-type="INSERT"><title id="_62ed09b7-781b-47da-89f4-7bb5dfb75f01">SA INSERT SubClause</title><num>4</num><p>In <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1364_3.8.0.xml#_6ff52a3c-f661-4540-bc88-52b7597794a9" id="_1796f700-e05e-4014-84b1-6800ff40b736" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">low rainfall intensity areas</xref> where the site classification is A, S, M, M-D, H, H1, H2, H-D, H1-D or H2-D in accordance with AS 2870, the height of the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1235_0.7.0.xml#_2c1e6053-5ce4-447e-965e-b393cf19b5ba" id="_3d967b0b-f978-48ff-86cf-cec91de5a15d" referencetype="Text" scope="local" synctargettext="false" type="glossterm">damp-proof course</xref> may be —</p><ol outputclass="alpha"><li id="_56c02604-3823-412b-bd00-0ee59a0e6d9b">15 mm above finished paved, concreted or landscaped areas; or</li><li id="_9432377b-0cd0-41c1-872f-56b6a030da93">0 mm if the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1235_0.7.0.xml#_2c1e6053-5ce4-447e-965e-b393cf19b5ba" id="_80a6959a-3c45-4df0-afe0-24d950dc03ac" referencetype="Text" scope="local" synctargettext="false" type="glossterm">damp-proof course</xref> is protected from the direct effects of the weather by a carport, verandah or the like.</li></ol></subclause></clause>