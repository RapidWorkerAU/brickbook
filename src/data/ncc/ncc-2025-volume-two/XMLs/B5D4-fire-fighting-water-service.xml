<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:xt="urn:xpressauthor:trackchanges" id="_336af446-7b0d-4f41-b705-3d6cd88b359d" outputclass="ncc-clause"><sptc>B5D4</sptc><title id="_f7be77ed-9855-41a3-9946-e4c0901544d8">Fire-fighting water service</title><archive-num>2019: B5.4</archive-num><subclause id="_b62895ff-6855-4222-a8b5-26144117a663" outputclass="subclause"><title id="_f781df38-6483-407b-b0c1-f71e181f1d24">SubClause</title><num>1</num><p>Each fire-fighting water service must—</p><ol outputclass="alpha"><li id="_2879c9d3-53a9-4bbe-b255-0b1504030f2a">be assigned a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1332_3.6.0.xml#_e221b82c-bc4b-43d2-ab64-522dd5dd1885" id="_8b681789-6ef8-47fd-b445-2194d8bde455" scope="local" type="abcb-glossentry">Hazard Rating</xref> in accordance with <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/9560_0.38.0.xml#_0374d305-c925-4ff9-9233-e5ecbc45fe70" id="_45f50fda-6550-4a50-8f53-ef8fa04e16b9" referencetype="Text" scope="local" synctargettext="false" type="subclause">B5D7(13)</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/9560_0.38.0.xml#_ffaf0f5a-f0b7-4d58-ad72-fbd9548604ec" id="_192e793e-0c44-4ea1-891f-54931ad88673" referencetype="Text" scope="local" synctargettext="false" type="subclause">B5D7(14)</xref>; and</li><li id="_927a0bd9-17b8-4fc9-82f5-a063dcb9a07b">be isolated from the <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1250_0.7.0.xml#_762d6a54-e28c-400b-b9c5-5fceac019a05" id="_fb3a136b-23d7-4ed0-832e-bd4c41522611" scope="local" type="abcb-glossentry">drinking water</xref> service by an appropriate <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1204_1.0.0.xml#_0fd1c6f9-50b2-4e0c-bda6-25c2bf33379f" id="_7c22401b-5d32-4ea4-a2da-5dd2c5e570d9" scope="local" type="abcb-glossentry">backflow prevention device</xref> which is selected and installed in accordance with AS/NZS 3500.1.</li></ol></subclause></clause>