<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_360502bc-1569-440e-a9e2-05c4391d349c" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>H3F2</sptc><title id="_7afdedff-2d6d-44c8-8d50-0ae68887fe89">Fire detection and early warning</title><archive-num>2019: F2.3.2</archive-num><subclause id="_86fe99f2-b9c4-44dc-82f1-0524f56e00c4" outputclass="subclause"><title id="_32d6645a-0716-4a0c-96d7-61b15409b358">SubClause</title><num>1</num><p>A Class 1 building is to be provided with safeguards so that occupants are warned of a fire in the building so that they may safely evacuate.</p></subclause></clause>