<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_39d284d8-9acd-4a4c-a051-8ae3cebdf886" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10a"/><facet building="Class 10b"/><facet building="Class 10c"/></meta><sptc>H4F3</sptc><title id="_0b5d8bb4-5988-4123-8045-470d05f2ab5d">Facilities</title><archive-num>2019: F2.4.3</archive-num><subclause id="_99c724f6-eab6-44c7-81ca-54b42def97c4" outputclass="subclause"><title id="_c72ef751-72fe-4f47-8b0c-0c8d9b36dc92">SubClause</title><num>1</num><p>A building is to be provided with suitable—</p><ol outputclass="alpha"><li id="_dcc09a52-8c81-488e-bb89-932fcca4610a">space and facilities for personal hygiene; and</li><li id="_d6d93ce5-fbb0-4c3a-a429-8d86621a7630">space or facilities for laundering; and</li><li id="_3c728061-50be-4e30-a3c2-5a778b8cfe22">space and facilities for the preparation and cooking of food; and</li><li id="_2fd293c2-8c2b-42e0-9f66-342ae1bdbbe4">space or other means to permit an unconscious occupant to be removed from a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1445_0.13.0.xml#_b30a308f-eb9f-4549-a6c1-19d5f32a5272" id="_1e120c0b-1e57-4070-b18e-a11c1fa27da4" scope="local" type="abcb-glossentry">sanitary compartment</xref>; and</li><li id="_dc78a5b5-b083-4314-8cc0-bccd3d3107e3">means for the sanitary disposal of waste water.</li></ol></subclause><callout id="_582ad595-b157-4788-b7af-9bbcf25f25c2"><callout-type ncc-info-type="application"/><p>H4F3 only applies to a Class 1 building.</p></callout></clause>