<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause id="_3bad4f23-4d92-4b59-9280-9e34df28b976" outputclass="ncc-clause"><meta><facet building="Class 1a"/><facet building="Class 1b"/><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10a"/><facet building="Class 10c"/></meta><sptc>H7F1</sptc><title id="_4399cb7f-d0cb-4170-8547-00139f7764c4">Swimming pool access</title><archive-num>2019: F2.7.1</archive-num><subclause id="_ef39221b-e5e0-4183-b9da-83908bc0dc45" outputclass="subclause"><title id="_ad141105-e011-4451-b218-cc260870f6a9">SubClause</title><num>1</num><p>A <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1487_0.7.0.xml#_4cbd9e00-0622-4dfd-9de4-913c80257732" id="_2997cef2-acdc-46ff-8e91-39432c35f1ba" scope="local" type="abcb-glossentry">swimming pool</xref> is to be provided with—</p><ol outputclass="alpha"><li id="_5a756902-c34a-4160-b718-425b370cc605">means to restrict access to it by young children; and</li><li id="_623130ca-90db-46c6-a126-f3e8211e96a4">means to reduce the possibility of a person being entrapped or injured due to suction by a water recirculation system.</li></ol></subclause><callout id="_e15f6626-ad42-478e-ac1b-c8390f6650e1"><callout-type ncc-info-type="application"/><p>H7F1 only applies to a <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1487_0.7.0.xml#_4cbd9e00-0622-4dfd-9de4-913c80257732" id="_6b97f1ba-598c-4829-9cef-e20e9d14150f" scope="local" type="abcb-glossentry">swimming pool</xref> with a depth of water more than 300 mm.</p></callout></clause>