<?xml version="1.0" encoding="UTF-8" standalone="no"?><?Xpress productLine="ncc-clause" ?><clause xmlns:qxa="urn:schemas-quark-com:xmlauthor" id="_d913ceb1-cd05-495e-a26f-ab42420e67ed" outputclass="ncc-clause"><meta><facet building="Class 2"/><facet building="Class 3"/><facet building="Class 4"/><facet building="Class 5"/><facet building="Class 6"/><facet building="Class 7a"/><facet building="Class 7b"/><facet building="Class 8"/><facet building="Class 9a"/><facet building="Class 9b"/><facet building="Class 9c"/><facet building="Class 10c"/></meta><sptc>H6D2</sptc><title id="_bdaa602d-622c-48e8-942d-dd9b0cca2613">Application of Part H6</title><archive-num>2019: 3.12.0</archive-num><subclause id="_1bf1a451-086f-4c55-9b4b-df44d64b8048" outputclass="subclause"><title id="_e0a8bcc2-46a0-47f7-8fcf-37afa9138cf3">SubClause</title><num>1</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_b796d961-82ba-46a4-b0c3-61ff0c652441" inv:access="external" scope="local" type="abcb-glossentry">Performance Requirement</xref> <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1946_3.17.0.xml#_ebeae85f-b094-4bad-a411-364a0334aa3b" id="_9a10577c-1f86-401a-9387-189ce2cb4792" inv:access="external" scope="local" type="clause">H6P1</xref> for the thermal performance of the building is satisfied by—</p><ol outputclass="alpha"><li id="_b39b5091-3cd3-40f5-8a79-5dd00e1c22d2">complying with <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1953_3.29.0.xml#_9f1997aa-d81a-453a-ad0b-8f6681e8eaf0" id="_17bf6d95-80a7-471a-815c-86634a0a7758" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">S42C2</xref>, using <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1342_0.23.0.xml#_c3e52045-6061-460e-93b7-bf5293430c15" id="_27c5b3ad-be30-4943-b753-7fcb43f787a5" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">house energy rating software</xref> and <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/7170_0.22.0.xml#_2ffda2c1-410f-4792-94d8-a8ec41ccdc7d" id="_9fe5d956-372f-4765-ad99-2720cddbe99c" referencetype="Text" scope="local" synctargettext="false" type="subclause">S42C4(1)</xref>; or</li><li id="_80d91954-108c-4584-a6b4-ce4123d9d510">complying with the following parts of the ABCB Housing Provisions—<ol><li><xref format="dita" href="qpp://assets/4232#_72b51e96-6a69-494d-a889-b470cddec7f9" id="_ba5e83ab-4543-4740-ac9d-5793008d5d58" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.2</xref>, for the building <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1269_0.5.0.xml#_13553d4f-118c-47e2-90ba-9892194abdf6" id="_95bbf34c-308f-4c77-94c8-9c9782fef468" scope="local" type="abcb-glossentry">fabric</xref>; and</li><li><xref format="dita" href="qpp://assets/4233#_057d2694-35fa-4a5e-88bd-fa309915541c" id="_7925b90c-233f-4c1d-a0e0-deea85e1bb3f" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.3</xref>, for the external <xref format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_9ec1a1a1-3e15-46fe-9879-584e2c0cd4f9" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref> and shading; and</li><li><xref format="dita" href="qpp://assets/4234#_09a0cfcb-49e7-4656-a327-9fbd0dbd1672" id="_9f5722ba-bf7f-4ba8-ba53-3f190d382019" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.4</xref>, for building sealing; and</li><li><xref format="dita" href="qpp://assets/4235#_be12359c-d7ea-4891-bb18-343ba3471652" id="_7f05f216-7f5c-4111-9773-1d6b4ea1869f" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Part 13.5</xref>, for ceiling fans.</li></ol></li></ol></subclause><subclause id="_48e12206-cba1-4205-b962-adcea1860e71" outputclass="subclause"><title id="_85d8ce0e-47b7-4de9-8521-2fbb6531c47b">SubClause</title><num>2</num><p><xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_22574fb5-3007-40bc-91dd-2ed6dae4a626" inv:access="external" scope="local" type="abcb-glossentry">Performance Requirement</xref> <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1947_3.15.0.xml#_e8d2c621-96a1-44a3-a7e7-0bfd6b7ab184" id="_e42cf865-9cc4-46fb-9330-82369bde94f6" inv:access="external" scope="local" type="clause">H6P2</xref> for the energy usage of the building is satisfied by—</p><ol outputclass="alpha"><li id="_4abb1638-d66b-46a7-8e08-f46ef4355e92">complying with <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/6272_0.9.0.xml#_da472c90-0099-4a3e-9739-3526a9379554" id="_2d33e8e3-585e-4dfe-a2d6-c5eedbf0a5c2" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">S42C3</xref> using <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1342_0.23.0.xml#_c3e52045-6061-460e-93b7-bf5293430c15" id="_54e48b58-f5bf-4495-aca4-015e193881de" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">house energy rating software</xref> and <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/7170_0.22.0.xml#_3d207b06-4ef1-4897-af3b-bd718298b315" id="_7c1267b4-ef14-430e-bcc0-6dd2941dc511" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="ncc-clause">S42C4(2)</xref>; or</li><li id="_206e2ef4-c4f9-484b-ad9a-90aebd8a5ea0">complying with <xref format="dita" href="qpp://assets/6395#_c364fa3f-9af5-4343-85ce-b17468853004" id="_7a1c0680-15ab-494b-b473-8984f0f68598" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">Parts 13.6</xref> and <xref format="dita" href="qpp://assets/4236#_a63a0b59-83de-4c2b-8fad-bca5e858ad75" id="_16085f57-85f8-4887-84be-2f749f7f9f79" publishing-id="housing" referencetype="Text" scope="external" synctargettext="false" type="standard-part">13.7</xref> of the ABCB Housing Provisions for a building with a total floor area not greater than 500 m².</li></ol></subclause><callout id="_12d6f7be-ad69-42dd-8900-e51ee751c5cb"><callout-type ncc-info-type="info"/><p>There are two Deemed-to-Satisfy pathways for complying with the energy efficiency <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1395_4.0.0.xml#_f7304862-3529-49d7-9f62-352bcbcb6294" id="_14031a58-57b6-4262-91d1-242266722c9d" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">Performance Requirements</xref>:</p><ul><li>Option 1 Energy Rating — applying <xref format="dita" href="qpp://assets/4631#_ee95f7ff-730f-4326-af4b-499c55a93f3f" id="_7c88fe14-8a63-4381-9db6-964f78ff7bda" publishing-id="vol1" referencetype="Text" scope="external" synctargettext="false" type="specification">Specification 42</xref> to achieve the heating and cooling loads, net equivalent energy usage, and other energy saving features such as thermal breaks, compensation for a loss of ceiling insulation, floor edge insulation and building sealing.</li><li>Option 2 Elemental Provisions — using Section 13 of the ABCB Housing Provisions to satisfy all the detailed provisions including building <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1269_0.5.0.xml#_13553d4f-118c-47e2-90ba-9892194abdf6" id="_d3bfc59c-841d-4870-b269-c93bc3bd0678" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">fabric</xref>, external <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1319_2.9.0.xml#_50325745-1d02-4c68-85ac-bd7c1a787b1e" id="_3e0c1753-42a4-43d3-b421-c270a89687a6" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">glazing</xref>, building sealing, ceiling fans, whole-of-home energy usage and <xref xmlns:inv="urn:xpressauthor:xpressdocument" format="dita" href="/tmp/QppServer/Publishing/8bd50c59-637c-4a79-8565-09cd674ed7ed/1456_25.0.0.xml#_242ba975-4cdf-4b84-9f41-b8d524ee17c2" id="_8d0b919e-c55a-4645-a114-1cd205110764" inv:access="external" referencetype="Text" scope="local" synctargettext="false" type="abcb-glossentry">services</xref>.</li></ul></callout></clause>